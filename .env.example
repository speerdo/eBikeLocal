# ===== DATABASE =====
# Neon DB connection string (postgres.js)
DATABASE_URL=postgresql://user:password@endpoint.neon.tech/dbname?sslmode=require

# ===== GOOGLE APIs =====
# Google Places API (New) — for data pipeline / shop discovery
GOOGLE_PLACES_API_KEY=
# Google Maps Embed API — separate restricted key for map embeds
GOOGLE_MAPS_EMBED_KEY=

# ===== AFFILIATE APIs =====
# AvantLink (Aventon, Lectric, EVELO, QuietKat, Blix, Rad, Electric Bike Co, REI)
AVANTLINK_API_KEY=
# ShareASale (Himiway, Engwe, Heybike)
SHAREASALE_API_TOKEN=
SHAREASALE_API_SECRET=
# Impact (Velotric)
IMPACT_ACCOUNT_SID=
IMPACT_AUTH_TOKEN=

# ===== SITE CONFIG =====
SITE_URL=https://ebikelocal.com
# Vercel deploy hook secret for webhook-triggered rebuilds
BUILD_HOOK_SECRET=
