---
import '@/styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description = 'Find eBike shops, brands, and bikes near you. Compare dealers, check which brands they carry, and shop the best electric bikes.',
  canonicalUrl = Astro.url.href,
  ogImage = '/og-default.png',
  jsonLd,
} = Astro.props;

const siteUrl = import.meta.env.SITE_URL || 'https://ebikelocal.com';
const fullOgImage = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;

const currentPath = Astro.url.pathname;
const navLinks = [
  { href: '/shops/', label: 'Find Shops' },
  { href: '/brands/', label: 'Brands' },
  { href: '/bikes/', label: 'Bikes' },
  { href: '/best/', label: 'Best Picks' },
  { href: '/guides/', label: 'Guides' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullOgImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="eBikeLocal" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullOgImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- JSON-LD -->
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}

    <slot name="head" />
  </head>

  <body class="min-h-screen bg-white text-surface-900 font-sans antialiased">

    <!-- ── Navigation ── -->
    <header id="site-header" class="sticky top-0 z-50 transition-all duration-200">
      <div class="border-b border-surface-200/80 bg-white/95 backdrop-blur-md">
        <nav class="mx-auto flex max-w-7xl items-center justify-between page-x py-3">

          <!-- Logo -->
          <a href="/" class="flex items-center gap-2.5 group" aria-label="eBikeLocal home">
            <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-brand-600 shadow-sm group-hover:bg-brand-700 transition-colors">
              <svg viewBox="0 0 32 32" fill="none" class="h-5 w-5">
                <circle cx="8" cy="22" r="5" stroke="white" stroke-width="2" fill="none"/>
                <circle cx="24" cy="22" r="5" stroke="white" stroke-width="2" fill="none"/>
                <path d="M8 22 L16 12 L24 22" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M16 12 L18 22" stroke="white" stroke-width="2" stroke-linecap="round"/>
                <path d="M20 12 L24 12 L24 15" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M13 12 L19 12" stroke="white" stroke-width="1.8" stroke-linecap="round"/>
                <path d="M15 7 L13 11 L15.5 11 L13.5 16 L19 10 L16 10 L18 7 Z" fill="#fbbf24"/>
              </svg>
            </div>
            <div class="leading-tight">
              <span class="font-display text-lg font-bold text-surface-900 group-hover:text-brand-600 transition-colors">
                eBike<span class="text-brand-600">Local</span>
              </span>
              <span class="hidden sm:block text-[10px] font-medium tracking-wide text-surface-400 uppercase -mt-0.5">Find. Compare. Ride.</span>
            </div>
          </a>

          <!-- Desktop nav -->
          <ul class="hidden items-center gap-1 lg:flex">
            {navLinks.map(link => (
              <li>
                <a
                  href={link.href}
                  class={`relative px-3 py-1.5 text-sm font-medium rounded-lg transition-colors ${
                    currentPath.startsWith(link.href)
                      ? 'text-brand-600 bg-brand-50'
                      : 'text-surface-600 hover:text-surface-900 hover:bg-surface-50'
                  }`}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>

          <!-- Right side -->
          <div class="flex items-center gap-2">
            <a
              href="/shops/"
              class="hidden sm:inline-flex items-center gap-1.5 rounded-lg bg-brand-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-brand-700 transition-colors"
            >
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
              Find a Shop
            </a>

            <!-- Mobile menu button -->
            <button
              id="mobile-menu-btn"
              class="lg:hidden flex h-9 w-9 items-center justify-center rounded-lg text-surface-600 hover:bg-surface-100 transition-colors"
              aria-label="Open menu"
              aria-expanded="false"
            >
              <svg id="menu-icon" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
              </svg>
              <svg id="close-icon" class="h-5 w-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>
        </nav>

        <!-- Mobile nav -->
        <div id="mobile-menu" class="hidden border-t border-surface-100 lg:hidden">
          <div class="mx-auto max-w-7xl page-x py-3 space-y-0.5">
            {navLinks.map(link => (
              <a
                href={link.href}
                class={`flex items-center py-2.5 px-3 rounded-lg text-sm font-medium transition-colors ${
                  currentPath.startsWith(link.href)
                    ? 'text-brand-600 bg-brand-50'
                    : 'text-surface-700 hover:text-surface-900 hover:bg-surface-50'
                }`}
              >
                {link.label}
              </a>
            ))}
            <div class="pt-2 pb-1">
              <a href="/shops/" class="flex items-center justify-center gap-2 rounded-lg bg-brand-600 py-2.5 text-sm font-semibold text-white">
                Find a Shop Near Me
              </a>
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- ── Main content ── -->
    <main>
      <slot />
    </main>

    <!-- ── Footer ── -->
    <footer class="mt-20 border-t border-surface-100 bg-surface-950 text-surface-400">
      <div class="mx-auto max-w-7xl page-x py-14">
        <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-5">
          <!-- Brand -->
          <div class="lg:col-span-2">
            <a href="/" class="flex items-center gap-2.5">
              <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-brand-600">
                <svg viewBox="0 0 32 32" fill="none" class="h-5 w-5">
                  <circle cx="8" cy="22" r="5" stroke="white" stroke-width="2" fill="none"/>
                  <circle cx="24" cy="22" r="5" stroke="white" stroke-width="2" fill="none"/>
                  <path d="M8 22 L16 12 L24 22" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M16 12 L18 22" stroke="white" stroke-width="2" stroke-linecap="round"/>
                  <path d="M15 7 L13 11 L15.5 11 L13.5 16 L19 10 L16 10 L18 7 Z" fill="#fbbf24"/>
                </svg>
              </div>
              <span class="font-display text-lg font-bold text-white">eBike<span class="text-brand-400">Local</span></span>
            </a>
            <p class="mt-3 text-sm leading-relaxed">
              The only directory that tells you which eBike brands each shop carries. Find local dealers, compare models, and ride smarter.
            </p>
            <p class="mt-4 text-xs text-surface-600">
              We earn commissions from affiliate links. This doesn't affect our editorial independence.
            </p>
          </div>

          <div>
            <h4 class="text-xs font-semibold uppercase tracking-wider text-surface-500 mb-3">Directory</h4>
            <ul class="space-y-2 text-sm">
              <li><a href="/shops/" class="hover:text-white transition-colors">Shop Directory</a></li>
              <li><a href="/brands/" class="hover:text-white transition-colors">eBike Brands</a></li>
              <li><a href="/bikes/" class="hover:text-white transition-colors">Browse Bikes</a></li>
              <li><a href="/categories/" class="hover:text-white transition-colors">Categories</a></li>
            </ul>
          </div>

          <div>
            <h4 class="text-xs font-semibold uppercase tracking-wider text-surface-500 mb-3">Resources</h4>
            <ul class="space-y-2 text-sm">
              <li><a href="/best/" class="hover:text-white transition-colors">Best Picks</a></li>
              <li><a href="/guides/" class="hover:text-white transition-colors">Guides</a></li>
              <li><a href="/guides/ebike-laws-by-state/" class="hover:text-white transition-colors">eBike Laws</a></li>
            </ul>
          </div>

          <div>
            <h4 class="text-xs font-semibold uppercase tracking-wider text-surface-500 mb-3">Company</h4>
            <ul class="space-y-2 text-sm">
              <li><a href="/disclosure/" class="hover:text-white transition-colors">Affiliate Disclosure</a></li>
              <li><a href="/privacy/" class="hover:text-white transition-colors">Privacy Policy</a></li>
              <li><a href="/terms/" class="hover:text-white transition-colors">Terms of Service</a></li>
            </ul>
          </div>
        </div>

        <div class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-surface-800 pt-8 text-xs sm:flex-row">
          <p>&copy; {new Date().getFullYear()} eBikeLocal. All rights reserved.</p>
          <p class="text-surface-600">Built for eBike riders, by eBike riders.</p>
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      const menuIcon = document.getElementById('menu-icon');
      const closeIcon = document.getElementById('close-icon');

      btn?.addEventListener('click', () => {
        const isOpen = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', String(!isOpen));
        menu?.classList.toggle('hidden');
        menuIcon?.classList.toggle('hidden');
        closeIcon?.classList.toggle('hidden');
      });

      // Shadow nav on scroll
      const header = document.getElementById('site-header');
      window.addEventListener('scroll', () => {
        if (window.scrollY > 10) {
          header?.classList.add('shadow-sm');
        } else {
          header?.classList.remove('shadow-sm');
        }
      }, { passive: true });
    </script>
  </body>
</html>
