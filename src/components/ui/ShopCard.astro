---
interface Props {
  name: string;
  slug: string;
  stateSlug: string;
  citySlug: string;
  address: string;
  city: string;
  stateCode: string;
  rating?: number | null;
  reviewCount?: number | null;
  brands?: string[];
  services?: string[];
  featuredImageUrl?: string | null;
  isEbikeSpecialist?: boolean;
}

const {
  name,
  slug,
  stateSlug,
  citySlug,
  address,
  city,
  stateCode,
  rating,
  reviewCount,
  brands = [],
  services = [],
  featuredImageUrl,
  isEbikeSpecialist = false,
} = Astro.props;

const href = `/shops/${stateSlug}/${citySlug}/${slug}/`;

const serviceLabels: Record<string, string> = {
  sales: 'Sales', repair: 'Repair', rental: 'Rental',
  test_rides: 'Test Rides', fitting: 'Fitting', assembly: 'Assembly',
};
---

<a href={href} class="group card-hover flex gap-4 rounded-2xl border border-surface-200 bg-white p-4 shadow-card">
  <!-- Image or placeholder -->
  {featuredImageUrl ? (
    <img
      src={featuredImageUrl}
      alt={name}
      class="h-24 w-24 shrink-0 rounded-xl object-cover"
      loading="lazy"
    />
  ) : (
    <div class="flex h-24 w-24 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-brand-50 to-brand-100">
      <svg class="h-10 w-10 text-brand-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
      </svg>
    </div>
  )}

  <div class="min-w-0 flex-1">
    <div class="flex items-start justify-between gap-2">
      <h3 class="font-display font-bold text-surface-900 group-hover:text-brand-600 transition-colors leading-snug">
        {name}
      </h3>
      {isEbikeSpecialist && (
        <span class="shrink-0 rounded-full bg-accent-50 px-2.5 py-0.5 text-xs font-semibold text-accent-600 ring-1 ring-accent-200">
          Specialist
        </span>
      )}
    </div>

    <p class="mt-1 text-sm text-surface-500">{address}, {city}, {stateCode}</p>

    {rating && (
      <div class="mt-1.5 flex items-center gap-1.5">
        <div class="flex">
          {[1,2,3,4,5].map(i => (
            <svg
              class={`h-3.5 w-3.5 ${i <= Math.round(rating) ? 'text-amber-400' : 'text-surface-200'}`}
              viewBox="0 0 20 20" fill="currentColor"
            >
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>
        <span class="text-sm font-semibold text-surface-900">{rating.toFixed(1)}</span>
        {reviewCount && <span class="text-xs text-surface-400">({reviewCount.toLocaleString()})</span>}
      </div>
    )}

    {brands.length > 0 && (
      <div class="mt-2 flex flex-wrap gap-1">
        {brands.slice(0, 5).map((brand) => (
          <span class="rounded-md bg-brand-50 px-2 py-0.5 text-xs font-medium text-brand-700 ring-1 ring-brand-100">
            {brand}
          </span>
        ))}
        {brands.length > 5 && (
          <span class="rounded-md bg-surface-100 px-2 py-0.5 text-xs text-surface-500">
            +{brands.length - 5} more
          </span>
        )}
      </div>
    )}

    {services.length > 0 && (
      <div class="mt-1.5 flex flex-wrap gap-1">
        {services.map((s) => (
          <span class="rounded bg-surface-100 px-1.5 py-0.5 text-[11px] text-surface-600">
            {serviceLabels[s] || s}
          </span>
        ))}
      </div>
    )}
  </div>

  <!-- Arrow indicator -->
  <div class="shrink-0 self-center text-surface-300 group-hover:text-brand-500 transition-colors">
    <svg class="h-5 w-5 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
    </svg>
  </div>
</a>
