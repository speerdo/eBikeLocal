---
interface Props {
  name: string;
  slug: string;
  stateSlug: string;
  citySlug: string;
  address: string;
  city: string;
  stateCode: string;
  rating?: number | null;
  reviewCount?: number | null;
  brands?: string[];
  services?: string[];
  featuredImageUrl?: string | null;
  isEbikeSpecialist?: boolean;
}

const {
  name,
  slug,
  stateSlug,
  citySlug,
  address,
  city,
  stateCode,
  rating,
  reviewCount,
  brands = [],
  services = [],
  featuredImageUrl,
  isEbikeSpecialist = false,
} = Astro.props;

const href = `/shops/${stateSlug}/${citySlug}/${slug}/`;

const serviceLabels: Record<string, string> = {
  sales: 'Sales', repair: 'Repair', rental: 'Rental',
  test_rides: 'Test Rides', fitting: 'Fitting', assembly: 'Assembly',
};

// Rating to star fill
const starsFull  = rating ? Math.floor(rating) : 0;
const starsHalf  = rating ? (rating % 1 >= 0.5 ? 1 : 0) : 0;
const starsEmpty = 5 - starsFull - starsHalf;
---

<a href={href} class="group card-hover flex gap-4 rounded-2xl border border-surface-200 bg-white p-4 shadow-card hover:border-brand-400/30">

  <!-- Shop image / placeholder -->
  <div class="shrink-0">
    {featuredImageUrl ? (
      <img
        src={featuredImageUrl}
        alt={`${name} — eBike shop in ${city}, ${stateCode}`}
        class="h-[88px] w-[88px] rounded-xl object-cover"
        loading="lazy"
      />
    ) : (
      <div class="flex h-[88px] w-[88px] items-center justify-center rounded-xl bg-gradient-to-br from-surface-50 to-surface-100 border border-surface-200">
        <!-- Map pin icon -->
        <svg class="h-9 w-9 text-surface-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
      </div>
    )}
  </div>

  <!-- Content -->
  <div class="min-w-0 flex-1">

    <!-- Name + specialist badge -->
    <div class="flex items-start justify-between gap-2">
      <h3 class="font-display font-700 text-surface-900 group-hover:text-brand-600 transition-colors leading-snug text-[0.95rem]">
        {name}
      </h3>
      {isEbikeSpecialist && (
        <span class="shrink-0 inline-flex items-center gap-1 rounded-full bg-brand-50 px-2 py-0.5 text-[11px] font-700 text-brand-600 ring-1 ring-brand-200/60">
          <svg class="h-2.5 w-2.5" viewBox="0 0 10 10" fill="currentColor" aria-hidden="true"><path d="M5 0l1.2 3.8H10L6.9 6.1l1.2 3.8L5 7.6l-3.1 2.3L3.1 6.1 0 3.8h3.8L5 0z"/></svg>
          Specialist
        </span>
      )}
    </div>

    <!-- Address -->
    <p class="mt-1 text-xs text-surface-500 leading-snug">
      {address}, {city}, {stateCode}
    </p>

    <!-- Rating -->
    {rating && (
      <div class="mt-1.5 flex items-center gap-1.5">
        <div class="flex items-center gap-0.5" aria-label={`${rating.toFixed(1)} out of 5 stars`}>
          {Array.from({ length: starsFull }).map(() => (
            <svg class="h-3 w-3 text-amber-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          ))}
          {starsHalf === 1 && (
            <svg class="h-3 w-3" viewBox="0 0 20 20" aria-hidden="true">
              <defs>
                <linearGradient id={`half-star-${slug}`}>
                  <stop offset="50%" stop-color="#fbbf24"/>
                  <stop offset="50%" stop-color="#e5e7eb"/>
                </linearGradient>
              </defs>
              <path fill={`url(#half-star-${slug})`} d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          )}
          {Array.from({ length: starsEmpty }).map(() => (
            <svg class="h-3 w-3 text-surface-200" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          ))}
        </div>
        <span class="text-xs font-700 text-surface-900">{rating.toFixed(1)}</span>
        {reviewCount && (
          <span class="text-[11px] text-surface-400">({reviewCount >= 1000 ? `${(reviewCount / 1000).toFixed(1)}k` : reviewCount})</span>
        )}
      </div>
    )}

    <!-- Brands -->
    {brands.length > 0 && (
      <div class="mt-2 flex flex-wrap gap-1">
        {brands.slice(0, 5).map((brand) => (
          <span
            class="inline-flex items-center gap-1 rounded-md bg-brand-50 px-2 py-0.5 text-[11px] font-600 text-brand-700 ring-1 ring-brand-100"
            title={brand === 'Rad Power Bikes' ? 'Dealer status may have changed — Rad Power Bikes filed Chapter 11 in Dec 2025' : undefined}
          >
            {brand}
            {brand === 'Rad Power Bikes' ? <span aria-hidden="true">⚠️</span> : null}
          </span>
        ))}
        {brands.length > 5 && (
          <span class="rounded-md bg-surface-100 px-2 py-0.5 text-[11px] text-surface-500">
            +{brands.length - 5}
          </span>
        )}
      </div>
    )}

    <!-- Services -->
    {services.length > 0 && (
      <div class="mt-1.5 flex flex-wrap gap-1">
        {services.map((s) => (
          <span class="rounded bg-surface-100 px-1.5 py-0.5 text-[10px] font-500 text-surface-500 uppercase tracking-wide">
            {serviceLabels[s] || s}
          </span>
        ))}
      </div>
    )}
  </div>

  <!-- Chevron -->
  <div class="shrink-0 self-center text-surface-300 group-hover:text-brand-500 transition-colors ml-1">
    <svg class="h-4 w-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
    </svg>
  </div>
</a>
