---
interface Props {
  name: string;
  slug: string;
  stateSlug: string;
  citySlug: string;
  address: string;
  city: string;
  stateCode: string;
  rating?: number | null;
  reviewCount?: number | null;
  brands?: string[];
  services?: string[];
  featuredImageUrl?: string | null;
  isEbikeSpecialist?: boolean;
}

const {
  name,
  slug,
  stateSlug,
  citySlug,
  address,
  city,
  stateCode,
  rating,
  reviewCount,
  brands = [],
  services = [],
  featuredImageUrl,
  isEbikeSpecialist = false,
} = Astro.props;

const href = `/shops/${stateSlug}/${citySlug}/${slug}/`;
---

<a href={href} class="group block rounded-lg border border-surface-200 bg-white p-4 shadow-sm transition-shadow hover:shadow-md">
  <div class="flex gap-4">
    {featuredImageUrl ? (
      <img
        src={featuredImageUrl}
        alt={name}
        class="h-20 w-20 shrink-0 rounded-md object-cover"
        loading="lazy"
      />
    ) : (
      <div class="flex h-20 w-20 shrink-0 items-center justify-center rounded-md bg-surface-100 text-surface-700">
        <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
      </div>
    )}

    <div class="min-w-0 flex-1">
      <div class="flex items-start justify-between gap-2">
        <h3 class="font-semibold text-surface-900 group-hover:text-brand-600 transition-colors truncate">
          {name}
        </h3>
        {isEbikeSpecialist && (
          <span class="shrink-0 rounded-full bg-accent-500/10 px-2 py-0.5 text-xs font-medium text-accent-600">
            eBike Specialist
          </span>
        )}
      </div>

      <p class="mt-0.5 text-sm text-surface-700">{address}, {city}, {stateCode}</p>

      {rating && (
        <div class="mt-1 flex items-center gap-1 text-sm">
          <span class="font-medium text-surface-900">{rating.toFixed(1)}</span>
          <svg class="h-4 w-4 text-amber-400" viewBox="0 0 20 20" fill="currentColor">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
          {reviewCount && <span class="text-surface-700">({reviewCount})</span>}
        </div>
      )}

      {brands.length > 0 && (
        <div class="mt-2 flex flex-wrap gap-1">
          {brands.slice(0, 4).map((brand) => (
            <span class="rounded bg-brand-50 px-1.5 py-0.5 text-xs font-medium text-brand-700">{brand}</span>
          ))}
          {brands.length > 4 && (
            <span class="rounded bg-surface-100 px-1.5 py-0.5 text-xs text-surface-700">+{brands.length - 4}</span>
          )}
        </div>
      )}

      {services.length > 0 && (
        <div class="mt-1.5 flex flex-wrap gap-1">
          {services.map((service) => (
            <span class="rounded bg-surface-100 px-1.5 py-0.5 text-xs text-surface-700">{service}</span>
          ))}
        </div>
      )}
    </div>
  </div>
</a>
