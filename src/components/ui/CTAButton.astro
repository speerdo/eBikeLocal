---
interface Props {
  href: string;
  brandName: string;
  price?: number | null;
  variant?: 'primary' | 'secondary';
}

const { href, brandName, price, variant = 'primary' } = Astro.props;

const classes = {
  primary: 'bg-brand-600 text-white hover:bg-brand-700',
  secondary: 'border border-surface-200 bg-white text-surface-900 hover:border-brand-600 hover:text-brand-600',
};
---

<a
  href={href}
  target="_blank"
  rel="nofollow noopener sponsored"
  class={`inline-flex items-center justify-center gap-2 rounded-lg px-5 py-2.5 text-sm font-semibold transition-colors ${classes[variant]}`}
>
  {price ? `$${price.toLocaleString()} at ${brandName}` : `Check Price at ${brandName}`}
</a>
