---
interface Props {
  name: string;
  slug: string;
  logoUrl?: string | null;
  size?: 'sm' | 'md';
}

const { name, slug, logoUrl, size = 'sm' } = Astro.props;

const sizeClasses = {
  sm: 'px-2 py-1 text-xs',
  md: 'px-3 py-1.5 text-sm',
};
---

<a
  href={`/brands/${slug}/`}
  class={`inline-flex items-center gap-1.5 rounded-full border border-surface-200 bg-white font-medium text-surface-900 transition-colors hover:border-brand-600 hover:text-brand-600 ${sizeClasses[size]}`}
>
  {logoUrl ? (
    <img src={logoUrl} alt={name} class="h-4 w-4 object-contain" loading="lazy" />
  ) : null}
  {name}
</a>
