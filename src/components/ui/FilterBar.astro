---
interface FilterOption {
  value: string;
  label: string;
  count?: number;
}

interface FilterGroup {
  name: string;
  param: string;
  options: FilterOption[];
}

interface Props {
  filters: FilterGroup[];
  currentUrl: URL;
}

const { filters, currentUrl } = Astro.props;
---

<div class="flex flex-wrap gap-3" id="filter-bar">
  {filters.map((group) => {
    const activeValue = currentUrl.searchParams.get(group.param);
    return (
      <div class="relative">
        <select
          name={group.param}
          class="appearance-none rounded-lg border border-surface-200 bg-white px-3 py-2 pr-8 text-sm font-medium text-surface-900 transition-colors hover:border-brand-600 focus:border-brand-600 focus:outline-none focus:ring-2 focus:ring-brand-600/20"
          data-filter-param={group.param}
        >
          <option value="">{group.name}</option>
          {group.options.map((opt) => (
            <option value={opt.value} selected={activeValue === opt.value}>
              {opt.label}{opt.count != null ? ` (${opt.count})` : ''}
            </option>
          ))}
        </select>
        <svg class="pointer-events-none absolute right-2 top-1/2 h-4 w-4 -translate-y-1/2 text-surface-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </div>
    );
  })}
</div>

<script>
  document.querySelectorAll('#filter-bar select').forEach((select) => {
    select.addEventListener('change', () => {
      const url = new URL(window.location.href);
      const param = (select as HTMLSelectElement).dataset.filterParam!;
      const value = (select as HTMLSelectElement).value;
      if (value) {
        url.searchParams.set(param, value);
      } else {
        url.searchParams.delete(param);
      }
      window.location.href = url.toString();
    });
  });
</script>
