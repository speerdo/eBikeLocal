---
import { bikeBrandHeroFallbackUrl, pickBikeHeroImageUrl } from '@lib/bikeImageUrl';
import {
  BRAND_LOGO_CARD_IMG_CLASS,
  BRAND_LOGO_CARD_SLOT_CLASS,
  getBrandLogoUrl,
} from '@lib/brandLogos';

interface Props {
  modelName: string;
  brandName: string;
  brandSlug: string;
  /** Raw `brands.logo_url` — resolved with curated `/logos/brands/` files via `getBrandLogoUrl` */
  brandLogoUrl?: string | null;
  /** Used for Clearbit fallback when no local logo and no `logo_url` */
  brandWebsite?: string | null;
  slug: string;
  msrp?: number | null;
  salePrice?: number | null;
  heroImageUrl?: string | null;
  /** Fallback when hero is missing or only stored as a relative URL */
  galleryImages?: string[] | null;
  motorWatts?: number | null;
  batteryWh?: number | null;
  rangeMilesHigh?: number | null;
  bestFor?: string | null;
  affiliateUrl?: string | null;
  hasTorqueSensor?: boolean | null;
  ebikeClass?: number | null;
}

const {
  modelName,
  brandName,
  brandSlug,
  brandLogoUrl,
  brandWebsite,
  slug,
  msrp,
  salePrice,
  heroImageUrl,
  galleryImages,
  affiliateUrl,
  motorWatts,
  batteryWh,
  rangeMilesHigh,
  bestFor,
  hasTorqueSensor,
  ebikeClass,
} = Astro.props;

const displayHeroUrl = pickBikeHeroImageUrl({
  slug,
  brandSlug,
  heroImageUrl,
  galleryImages,
  affiliateUrl,
});
const brandHeroFallbackUrl = bikeBrandHeroFallbackUrl(brandSlug);
const imgBrandFallback =
  brandHeroFallbackUrl && brandHeroFallbackUrl !== displayHeroUrl ? brandHeroFallbackUrl : '';

const displayPrice = salePrice || msrp;
const hasDiscount  = salePrice && msrp && salePrice < msrp;
const href = `/bikes/${brandSlug}/${slug}/`;

const resolvedBrandLogoUrl = getBrandLogoUrl({
  slug: brandSlug,
  logo_url: brandLogoUrl,
  website: brandWebsite ?? null,
});
---

<div class="group card-hover flex flex-col overflow-hidden rounded-2xl border border-surface-200 bg-white shadow-card hover:border-brand-400/30">

  <!-- Image area -->
  <a href={href} class="block overflow-hidden bg-[#ffffff]" tabindex="-1" aria-hidden="true">
    {displayHeroUrl ? (
      <img
        src={displayHeroUrl}
        alt={`${brandName} ${modelName}`}
        class="h-52 w-full bg-[#ffffff] object-contain p-4 transition-transform duration-300 group-hover:scale-105"
        loading="lazy"
        referrerpolicy="no-referrer"
        data-brand-fallback={imgBrandFallback}
        onerror="(function(el){var b=el.dataset.brandFallback;if(b&&el.src!==b){el.src=b;}else{el.onerror=null;el.style.visibility='hidden';}})(this)"
      />
    ) : (
      <div class="flex h-52 w-full items-center justify-center bg-[#ffffff]">
        <!-- Bike silhouette placeholder -->
        <svg class="h-20 w-20 text-surface-200" viewBox="0 0 80 60" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="16" cy="44" r="12"/>
          <circle cx="64" cy="44" r="12"/>
          <path d="M16 44 L38 22 L64 44"/>
          <path d="M38 22 L42 44"/>
          <path d="M52 20 L64 20 L64 28"/>
          <path d="M32 20 L48 20"/>
          <!-- lightning bolt -->
          <path d="M36 10 L31 19 L37 19 L32 28 L45 17 L39 17 L44 10 Z" fill="currentColor" stroke="none" class="text-surface-200"/>
        </svg>
      </div>
    )}
  </a>

  <!-- Card body -->
  <div class="flex flex-1 flex-col p-4">

    <a href={href} class="block">
      <div class="min-w-0">
        {resolvedBrandLogoUrl ? (
          <div class={BRAND_LOGO_CARD_SLOT_CLASS}>
            <img
              src={resolvedBrandLogoUrl}
              alt={brandName}
              class={BRAND_LOGO_CARD_IMG_CLASS}
              loading="lazy"
              referrerpolicy="no-referrer"
            />
          </div>
        ) : (
          <p class="text-[11px] font-700 uppercase tracking-widest text-brand-600">{brandName}</p>
        )}
      </div>
      <h3 class="mt-2 font-display font-700 leading-snug text-surface-900 transition-colors group-hover:text-brand-600">
        {modelName}
      </h3>
      {bestFor && (
        <p class="mt-2 text-sm italic leading-snug text-surface-600">
          {bestFor}
        </p>
      )}
    </a>

    <!-- Price -->
    {displayPrice && (
      <div class="mt-2.5 flex items-baseline gap-2">
        <span class="font-display text-xl font-800 text-surface-900">
          ${displayPrice.toLocaleString()}
        </span>
        {hasDiscount && (
          <span class="text-sm text-surface-400 line-through">${msrp!.toLocaleString()}</span>
        )}
        {ebikeClass && (
          <span class="ml-auto shrink-0 text-[11px] font-600 text-surface-400">Class {ebikeClass}</span>
        )}
      </div>
    )}

    <!-- Specs row -->
    <div class="mt-3 flex flex-wrap gap-1.5">
      {motorWatts && (
        <span class="inline-flex items-center gap-1 rounded-full bg-amber-50 px-2.5 py-1 text-[11px] font-600 text-amber-700 ring-1 ring-amber-100">
          <svg class="h-3 w-3" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M7 2L2 9h5v5l7-7H9L14 2z"/></svg>
          {motorWatts}W
        </span>
      )}
      {batteryWh && (
        <span class="inline-flex items-center gap-1 rounded-full bg-brand-50 px-2.5 py-1 text-[11px] font-600 text-brand-700 ring-1 ring-brand-100">
          <svg class="h-3 w-3" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <rect x="1" y="4" width="11" height="8" rx="1.5"/><path d="M12 7h2v2h-2" stroke-linecap="round" stroke-linejoin="round"/><path d="M3.5 7.5h6" stroke-linecap="round"/>
          </svg>
          {batteryWh}Wh
        </span>
      )}
      {rangeMilesHigh && (
        <span class="inline-flex items-center gap-1 rounded-full bg-electric-50 px-2.5 py-1 text-[11px] font-600 text-electric-700 ring-1 ring-electric-100">
          <svg class="h-3 w-3" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M2 8h12M10 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round"/></svg>
          {rangeMilesHigh}mi
        </span>
      )}
      {hasTorqueSensor && (
        <span class="inline-flex items-center gap-1 rounded-full bg-accent-50 px-2.5 py-1 text-[11px] font-600 text-accent-700 ring-1 ring-accent-100/60">
          <svg class="h-3 w-3" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 1a7 7 0 100 14A7 7 0 008 1zm0 2a5 5 0 110 10A5 5 0 018 3zm0 1.5a3.5 3.5 0 100 7 3.5 3.5 0 000-7zm0 1.5a2 2 0 110 4 2 2 0 010-4z"/></svg>
          Torque
        </span>
      )}
    </div>

    <div class="flex-1" />

    <!-- CTA -->
    {affiliateUrl ? (
      <a
        href={affiliateUrl}
        target="_blank"
        rel="nofollow noopener sponsored"
        class="mt-4 flex items-center justify-center gap-1.5 btn-volt rounded-xl py-2.5 text-sm"
        onclick="event.stopPropagation()"
        aria-label={`Check price for ${brandName} ${modelName} at ${brandName}.com`}
      >
        Check Price at {brandName}
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
        </svg>
      </a>
    ) : (
      <a href={href} class="mt-4 flex items-center justify-center gap-1 rounded-xl border border-surface-200 py-2.5 text-sm font-600 text-surface-700 transition-colors hover:border-brand-400/50 hover:text-brand-700">
        View Details →
      </a>
    )}
  </div>
</div>
