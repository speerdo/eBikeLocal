---
interface Props {
  modelName: string;
  brandName: string;
  brandSlug: string;
  slug: string;
  msrp?: number | null;
  salePrice?: number | null;
  heroImageUrl?: string | null;
  motorWatts?: number | null;
  batteryWh?: number | null;
  rangeMilesHigh?: number | null;
  bestFor?: string | null;
  expertRating?: number | null;
  affiliateUrl?: string | null;
}

const {
  modelName,
  brandName,
  brandSlug,
  slug,
  msrp,
  salePrice,
  heroImageUrl,
  motorWatts,
  batteryWh,
  rangeMilesHigh,
  bestFor,
  expertRating,
  affiliateUrl,
} = Astro.props;

const displayPrice = salePrice || msrp;
const hasDiscount = salePrice && msrp && salePrice < msrp;
const href = `/bikes/${brandSlug}/${slug}/`;

// Rating color
const ratingColor = expertRating
  ? expertRating >= 9 ? 'bg-accent-500' : expertRating >= 7 ? 'bg-brand-600' : 'bg-surface-500'
  : '';
---

<div class="group card-hover relative flex flex-col overflow-hidden rounded-2xl border border-surface-200 bg-white shadow-card">
  {bestFor && (
    <div class="absolute top-3 left-3 z-10">
      <span class="rounded-lg bg-accent-500 px-2.5 py-1 text-xs font-bold text-white shadow-sm">
        {bestFor}
      </span>
    </div>
  )}

  {expertRating && (
    <div class="absolute top-3 right-3 z-10">
      <span class={`flex h-9 w-9 items-center justify-center rounded-xl text-xs font-extrabold text-white shadow-sm ${ratingColor}`}>
        {expertRating.toFixed(1)}
      </span>
    </div>
  )}

  <!-- Image -->
  <a href={href} class="block">
    {heroImageUrl ? (
      <img
        src={heroImageUrl}
        alt={`${brandName} ${modelName}`}
        class="h-48 w-full bg-surface-50 object-contain p-4 transition-transform duration-300 group-hover:scale-105"
        loading="lazy"
      />
    ) : (
      <div class="flex h-48 w-full items-center justify-center bg-gradient-to-br from-surface-50 to-surface-100">
        <svg class="h-16 w-16 text-surface-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
      </div>
    )}
  </a>

  <div class="flex flex-1 flex-col p-4">
    <a href={href}>
      <p class="text-xs font-semibold uppercase tracking-wide text-brand-600">{brandName}</p>
      <h3 class="mt-0.5 font-display font-bold text-surface-900 group-hover:text-brand-600 transition-colors leading-snug">
        {modelName}
      </h3>
    </a>

    {displayPrice && (
      <div class="mt-2 flex items-baseline gap-2">
        <span class="font-display text-xl font-extrabold text-surface-900">
          ${displayPrice.toLocaleString()}
        </span>
        {hasDiscount && (
          <span class="text-sm text-surface-400 line-through">${msrp!.toLocaleString()}</span>
        )}
      </div>
    )}

    <!-- Key specs pills -->
    <div class="mt-3 flex flex-wrap gap-1.5">
      {motorWatts && (
        <span class="flex items-center gap-1 rounded-full bg-amber-50 px-2.5 py-1 text-xs font-medium text-amber-700 ring-1 ring-amber-100">
          ⚡ {motorWatts}W
        </span>
      )}
      {batteryWh && (
        <span class="flex items-center gap-1 rounded-full bg-brand-50 px-2.5 py-1 text-xs font-medium text-brand-700 ring-1 ring-brand-100">
          🔋 {batteryWh}Wh
        </span>
      )}
      {rangeMilesHigh && (
        <span class="flex items-center gap-1 rounded-full bg-accent-50 px-2.5 py-1 text-xs font-medium text-accent-700 ring-1 ring-accent-100">
          📏 {rangeMilesHigh}mi
        </span>
      )}
    </div>

    <!-- Spacer -->
    <div class="flex-1"></div>

    {affiliateUrl && (
      <a
        href={affiliateUrl}
        target="_blank"
        rel="nofollow noopener sponsored"
        class="mt-4 flex items-center justify-center gap-1.5 rounded-xl bg-brand-600 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-brand-700 active:scale-95"
        onclick="event.stopPropagation()"
      >
        Check Price at {brandName}
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    )}
  </div>
</div>
