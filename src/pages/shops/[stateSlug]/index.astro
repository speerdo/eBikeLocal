---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/ui/Breadcrumb.astro';
import MultiPinMap from '@components/ui/MultiPinMap.astro';
import sql from '@lib/neon';

export async function getStaticPaths() {
  const states = await sql`SELECT code, name, slug, ebike_law_summary, ebike_classes_allowed, rebate_programs, shop_count FROM states`;
  const cities = await sql`SELECT name, slug, state_code, shop_count, latitude, longitude FROM cities WHERE has_dedicated_page = true ORDER BY shop_count DESC`;

  return states.map((state) => ({
    params: { stateSlug: state.slug },
    props: {
      state,
      cities: cities.filter((c) => c.state_code === state.code),
    },
  }));
}

const { state, cities } = Astro.props;

// Live deduplicated shop counts — mirrors the dedup logic in [citySlug]/index.astro
const liveCountRows = await sql`
  WITH normalized AS (
    SELECT
      s.city,
      COALESCE(
        NULLIF(s.normalized_address, ''),
        LOWER(TRIM(REGEXP_REPLACE(
          REGEXP_REPLACE(
            REGEXP_REPLACE(
              REGEXP_REPLACE(
                REGEXP_REPLACE(
                  REGEXP_REPLACE(
                    REGEXP_REPLACE(
                      REGEXP_REPLACE(COALESCE(s.address_line1, ''), '\\m(street)\\M', 'st', 'gi'),
                      '\\m(avenue)\\M', 'ave', 'gi'
                    ),
                    '\\m(road)\\M', 'rd', 'gi'
                  ),
                  ',?\\s*#\\s*[a-z0-9]+', '', 'gi'
                ),
                ',?\\s*\\m(ste|suite|unit|apt|apartment)\\M\\.?\\s*#?\\s*[a-z0-9]*', '', 'gi'
              ),
              '\\s+[a-z]\\s*$', '', 'g'
            ),
            ',', ' '
          ),
          '\\s+', ' ', 'g'
        )))
      ) AS dedup_key,
      s.google_review_count,
      s.google_rating,
      s.name AS shop_name
    FROM shops s
    WHERE s.state_code = ${state.code}
      AND (s.google_business_status IS NULL OR s.google_business_status != 'CLOSED_PERMANENTLY')
      AND COALESCE(s.listing_status, 'active') = 'active'
  ),
  ranked AS (
    SELECT
      n.city,
      ROW_NUMBER() OVER (
        PARTITION BY n.city, n.dedup_key
        ORDER BY n.google_review_count DESC NULLS LAST, n.google_rating DESC NULLS LAST, n.shop_name ASC
      ) AS rn
    FROM normalized n
  )
  SELECT city, COUNT(*) AS live_count
  FROM ranked
  WHERE rn = 1
  GROUP BY city
`;

const liveCountMap = new Map<string, number>(
  liveCountRows.map((r: any) => [r.city as string, Number(r.live_count)])
);

const liveStateTotal = liveCountRows.reduce((sum: number, r: any) => sum + Number(r.live_count), 0);

// Alphabetical default; count-sorted available for the client-side toggle
const citiesByName = [...cities].sort((a: any, b: any) =>
  String(a.name).localeCompare(String(b.name))
);
const sortedCities = citiesByName; // alias used by map/count references below

const topBrands = await sql`
  SELECT b.name, b.slug, COUNT(*) as shop_count
  FROM shop_brands sb
  JOIN brands b ON b.id = sb.brand_id
  JOIN shops s ON s.id = sb.shop_id
  WHERE s.state_code = ${state.code}
    AND COALESCE(s.listing_status, 'active') = 'active'
  GROUP BY b.id, b.name, b.slug
  ORDER BY shop_count DESC
  LIMIT 10
`;

const stateContextByCode: Record<string, string> = {
  CO: 'Colorado riders often split usage between Front Range commuting and mountain-town trail access, so dealer support and service depth matter as much as headline specs.',
  CA: 'California demand spans dense urban commutes, coastal recreation, and long-distance rail-trail riding, which creates a wide mix of commuter, cargo, and performance setups.',
  WA: 'Washington riders often balance wet-weather commuting with year-round hill climbs, making component durability and brake quality especially important.',
  OR: 'Oregon buyers typically prioritize all-weather reliability and practical commuter builds for mixed city and greenway riding.',
  TX: 'Texas shoppers often focus on higher-speed commuting range and heat-tolerant battery performance across longer suburban distances.',
};

const stateSpecificSentence = (() => {
  if (stateContextByCode[state.code]) return stateContextByCode[state.code];
  if (Array.isArray(state.rebate_programs) && state.rebate_programs.length > 0) {
    return `${state.name} also has active rebate and incentive programs that can materially change total purchase cost, so check eligibility before you buy.`;
  }
  if (cities.length >= 30) {
    return `${state.name} has broad dealer coverage across major metros and smaller towns, so comparing shops by brand availability can save a lot of time before test rides.`;
  }
  return `Local conditions, terrain, and service availability vary across ${state.name}, so comparing dealer coverage by city can help narrow your shortlist faster.`;
})();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `eBike Shops in ${state.name}`,
  description: `Find ${liveStateTotal} eBike shops in ${state.name}.`,
};
---

<BaseLayout
  title={`eBike Shops in ${state.name} — Find Local Dealers | eBikeLocal`}
  description={`Find ${liveStateTotal} electric bike shops across ${sortedCities.length} cities in ${state.name}. Browse by city, filter by brand, and discover local dealers carrying Aventon, Trek, Specialized, and more.`}
  jsonLd={jsonLd}
>
  <div class="mx-auto max-w-7xl page-x py-8">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: 'Shops', href: '/shops/' },
      { label: state.name },
    ]} />

    <h1 class="mt-6 text-3xl font-extrabold text-surface-900 md:text-4xl">
      eBike Shops in {state.name}
    </h1>
    <p class="mt-2 text-lg text-surface-700">
      {liveStateTotal} electric bike {liveStateTotal === 1 ? 'shop' : 'shops'} across {sortedCities.length} {sortedCities.length === 1 ? 'city' : 'cities'}.
    </p>

    {(() => {
      const topBrandNames = topBrands.slice(0, 3).map((b: any) => b.name);
      const brandStr = topBrandNames.length > 0
        ? `${topBrandNames.slice(0, -1).join(', ')}${topBrandNames.length > 1 ? ', and ' : ''}${topBrandNames[topBrandNames.length - 1]} are among the most widely carried brands across ${state.name} dealers.`
        : '';
      return (
        <p class="mt-3 max-w-2xl text-surface-600 leading-relaxed">
          {state.name} has {liveStateTotal.toLocaleString()} electric bike shops spanning {sortedCities.length} cities.{' '}
          {brandStr}{' '}
          {stateSpecificSentence}{' '}
          Browse by city below or use the brand chips on city pages to filter shops by what you want to test-ride.
        </p>
      );
    })()}

    <!-- State map with city markers -->
    {(() => {
      const cityPins = sortedCities
        .filter((c: any) => c.latitude && c.longitude)
        .map((c: any) => {
          const liveCount = liveCountMap.get(c.name) ?? Number(c.shop_count ?? 0);
          return {
            name: `${c.name} (${liveCount} shop${liveCount !== 1 ? 's' : ''})`,
            href: `/shops/${state.slug}/${c.slug}/`,
            latitude: Number(c.latitude),
            longitude: Number(c.longitude),
          };
        });
      return cityPins.length > 0 ? (
        <div class="mt-6">
          <MultiPinMap pins={cityPins} zoom={7} height="380px" />
        </div>
      ) : null;
    })()}

    <!-- Cities grid -->
    <section class="mt-10">
      <div class="flex items-center justify-between">
        <h2 class="text-xl font-bold text-surface-900">Cities with eBike Shops</h2>
        <div class="flex rounded-lg border border-surface-200 text-sm font-medium overflow-hidden">
          <button
            id="sort-alpha"
            data-sort="alpha"
            class="px-3 py-1.5 bg-brand-600 text-white transition-colors"
          >A–Z</button>
          <button
            id="sort-count"
            data-sort="count"
            class="px-3 py-1.5 bg-white text-surface-700 hover:bg-surface-50 transition-colors"
          ># Shops</button>
        </div>
      </div>
      <div id="cities-grid" class="mt-4 grid gap-3 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
        {sortedCities.map((city: any) => {
          const liveCount = liveCountMap.get(city.name) ?? Number(city.shop_count ?? 0);
          return (
            <a
              href={`/shops/${state.slug}/${city.slug}/`}
              data-name={city.name}
              data-count={liveCount}
              class="flex items-center justify-between rounded-lg border border-surface-200 px-4 py-3 transition-colors hover:border-brand-600 hover:bg-brand-50"
            >
              <span class="font-medium text-surface-900">{city.name}</span>
              {liveCount > 0 && (
                <span class="text-sm text-surface-700">{liveCount}</span>
              )}
            </a>
          );
        })}
      </div>
    </section>

    <script>
      const grid = document.getElementById('cities-grid')!;
      const btnAlpha = document.getElementById('sort-alpha')!;
      const btnCount = document.getElementById('sort-count')!;

      function applySort(mode: 'alpha' | 'count') {
        const cards = Array.from(grid.children) as HTMLElement[];
        cards.sort((a, b) => {
          if (mode === 'alpha') {
            return (a.dataset.name ?? '').localeCompare(b.dataset.name ?? '');
          }
          return Number(b.dataset.count ?? 0) - Number(a.dataset.count ?? 0);
        });
        cards.forEach((el) => grid.appendChild(el));

        const activeClass = ['bg-brand-600', 'text-white'];
        const inactiveClass = ['bg-white', 'text-surface-700', 'hover:bg-surface-50'];

        if (mode === 'alpha') {
          btnAlpha.classList.add(...activeClass);
          btnAlpha.classList.remove(...inactiveClass);
          btnCount.classList.add(...inactiveClass);
          btnCount.classList.remove(...activeClass);
        } else {
          btnCount.classList.add(...activeClass);
          btnCount.classList.remove(...inactiveClass);
          btnAlpha.classList.add(...inactiveClass);
          btnAlpha.classList.remove(...activeClass);
        }
      }

      btnAlpha.addEventListener('click', () => applySort('alpha'));
      btnCount.addEventListener('click', () => applySort('count'));
    </script>

    <!-- Top brands in state -->
    {topBrands.length > 0 && (
      <section class="mt-12">
        <h2 class="text-xl font-bold text-surface-900">Top eBike Brands in {state.name}</h2>
        <div class="mt-4 flex flex-wrap gap-2">
          {topBrands.map((brand) => (
            <a
              href={`/brands/${brand.slug}/`}
              class="rounded-full border border-surface-200 px-3 py-1.5 text-sm font-medium text-surface-900 transition-colors hover:border-brand-600 hover:text-brand-600"
            >
              {brand.name} ({brand.shop_count})
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- eBike law summary -->
    {state.ebike_law_summary && (
      <section class="mt-12 rounded-lg border border-surface-200 bg-surface-50 p-6">
        <h2 class="text-xl font-bold text-surface-900">eBike Laws in {state.name}</h2>
        <p class="mt-2 text-surface-700">{state.ebike_law_summary}</p>
        {state.ebike_classes_allowed && (
          <p class="mt-2 text-sm text-surface-700"><strong>Classes allowed:</strong> {state.ebike_classes_allowed}</p>
        )}
        <a
          href={`/guides/ebike-laws/${state.slug}/`}
          class="mt-3 inline-block text-sm font-medium text-brand-600 hover:underline"
        >
          Read full {state.name} eBike law guide →
        </a>
      </section>
    )}

    <!-- Rebate programs -->
    {state.rebate_programs && Array.isArray(state.rebate_programs) && state.rebate_programs.length > 0 && (
      <section class="mt-8">
        <h2 class="text-xl font-bold text-surface-900">eBike Rebate Programs in {state.name}</h2>
        <div class="mt-4 space-y-3">
          {state.rebate_programs.map((program: any) => (
            <div class="rounded-lg border border-surface-200 p-4">
              <h3 class="font-semibold text-surface-900">{program.name}</h3>
              {program.amount && <p class="text-sm text-accent-600 font-medium">Up to {program.amount}</p>}
              {program.eligibility && <p class="mt-1 text-sm text-surface-700">{program.eligibility}</p>}
              {program.url && (
                <a href={program.url} target="_blank" rel="noopener" class="mt-1 inline-block text-sm text-brand-600 hover:underline">
                  Learn more →
                </a>
              )}
            </div>
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>
