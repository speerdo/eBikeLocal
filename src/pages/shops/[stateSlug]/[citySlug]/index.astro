---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/ui/Breadcrumb.astro';
import ShopCard from '@components/ui/ShopCard.astro';
import MultiPinMap from '@components/ui/MultiPinMap.astro';
import sql from '@lib/neon';

export async function getStaticPaths() {
  const cities = await sql`
    SELECT c.id, c.name, c.slug, c.state_code, c.latitude, c.longitude, c.shop_count,
           s.name as state_name, s.slug as state_slug
    FROM cities c
    JOIN states s ON s.code = c.state_code
    WHERE c.has_dedicated_page = true
  `;

  return cities.map((city) => ({
    params: { stateSlug: city.state_slug, citySlug: city.slug },
    props: { city },
  }));
}

const { city } = Astro.props;
const cityLat = city.latitude != null ? Number(city.latitude) : NaN;
const cityLng = city.longitude != null ? Number(city.longitude) : NaN;
const hasCityCoords = Number.isFinite(cityLat) && Number.isFinite(cityLng) && (cityLat !== 0 || cityLng !== 0);

const shops = await sql`
  WITH scoped_shops AS (
    SELECT
      s.*,
      COALESCE(
        NULLIF(s.normalized_address, ''),
        LOWER(TRIM(REGEXP_REPLACE(
          REGEXP_REPLACE(
            REGEXP_REPLACE(
              REGEXP_REPLACE(
                REGEXP_REPLACE(
                  REGEXP_REPLACE(
                    REGEXP_REPLACE(
                      REGEXP_REPLACE(COALESCE(s.address_line1, ''), '\\m(street)\\M', 'st', 'gi'),
                      '\\m(avenue)\\M', 'ave', 'gi'
                    ),
                    '\\m(road)\\M', 'rd', 'gi'
                  ),
                  ',?\\s*#\\s*[a-z0-9]+', '', 'gi'
                ),
                ',?\\s*\\m(ste|suite|unit|apt|apartment)\\M\\.?\\s*#?\\s*[a-z0-9]*', '', 'gi'
              ),
              '\\s+[a-z]\\s*$', '', 'g'
            ),
            ',', ' '
          ),
          '\\s+', ' ', 'g'
        )))
      ) AS dedup_key
    FROM shops s
    WHERE s.city = ${city.name} AND s.state_code = ${city.state_code}
      AND (s.google_business_status IS NULL OR s.google_business_status != 'CLOSED_PERMANENTLY')
      AND COALESCE(s.listing_status, 'active') = 'active'
  ),
  ranked_shops AS (
    SELECT
      ss.*,
      ROW_NUMBER() OVER (
        PARTITION BY ss.city, ss.state_code, ss.dedup_key
        ORDER BY ss.google_review_count DESC NULLS LAST, ss.google_rating DESC NULLS LAST, ss.name ASC
      ) AS rank_in_address
    FROM scoped_shops ss
  )
  SELECT
    rs.*,
    (
      SELECT array_agg(DISTINCT b.name) FILTER (WHERE b.name IS NOT NULL)
      FROM shop_brands sb
      JOIN brands b ON b.id = sb.brand_id
      WHERE sb.shop_id = rs.id
    ) AS brand_names
  FROM ranked_shops rs
  WHERE rs.rank_in_address = 1
  ORDER BY rs.google_rating DESC NULLS LAST, rs.google_review_count DESC NULLS LAST, rs.name
`;

const brandCounts = await sql`
  SELECT b.name, b.slug, COUNT(*) as count
  FROM shop_brands sb
  JOIN brands b ON b.id = sb.brand_id
  JOIN shops s ON s.id = sb.shop_id
  WHERE s.city = ${city.name} AND s.state_code = ${city.state_code}
    AND COALESCE(s.listing_status, 'active') = 'active'
  GROUP BY b.id, b.name, b.slug
  ORDER BY count DESC
`;

const nearbyCities = await sql`
  SELECT
    c.name,
    c.slug,
    c.shop_count,
    s.slug as state_slug,
    c.latitude,
    c.longitude
  FROM cities c
  JOIN states s ON s.code = c.state_code
  WHERE c.state_code = ${city.state_code}
    AND c.slug != ${city.slug}
    AND c.has_dedicated_page = true
  ORDER BY c.name
  LIMIT 60
`;

const mapPins = shops
  .filter((s) => s.latitude && s.longitude)
  .map((s) => ({
    name: s.name,
    href: `/shops/${city.state_slug}/${city.slug}/${s.slug}/`,
    latitude: Number(s.latitude),
    longitude: Number(s.longitude),
  }));

const topBrandNames = brandCounts
  .map((b: any) => (b.name || '').trim())
  .filter(Boolean)
  .slice(0, 3);

const extraBrandCount = brandCounts.length - 3;
const brandListText = topBrandNames.length === 0
  ? ''
  : extraBrandCount > 0
    ? `${topBrandNames.join(', ')}, and ${extraBrandCount} more ${extraBrandCount === 1 ? 'brand' : 'brands'}`
    : topBrandNames.join(', ');

function haversineMiles(lat1: number, lon1: number, lat2: number, lon2: number) {
  const toRad = (d: number) => (d * Math.PI) / 180;
  const R = 3958.8;
  const dLat = toRad(lat2 - lat1);
  const dLon = toRad(lon2 - lon1);
  const a =
    Math.sin(dLat / 2) ** 2 +
    Math.cos(toRad(lat1)) * Math.cos(toRad(lat2)) * Math.sin(dLon / 2) ** 2;
  const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
  return R * c;
}

const nearbyCitiesSorted = nearbyCities
  .map((nc: any) => {
    const lat = nc.latitude != null ? Number(nc.latitude) : NaN;
    const lng = nc.longitude != null ? Number(nc.longitude) : NaN;
    const hasCoords = hasCityCoords && Number.isFinite(lat) && Number.isFinite(lng) && (lat !== 0 || lng !== 0);
    return {
      ...nc,
      distance_miles: hasCoords ? haversineMiles(cityLat, cityLng, lat, lng) : null,
    };
  })
  .sort((a: any, b: any) => {
    if (a.distance_miles != null && b.distance_miles != null) return a.distance_miles - b.distance_miles;
    if (a.distance_miles != null) return -1;
    if (b.distance_miles != null) return 1;
    return Number(b.shop_count || 0) - Number(a.shop_count || 0);
  })
  .slice(0, 8);

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `eBike shops in ${city.name}, ${city.state_code}`,
  itemListElement: shops.slice(0, 100).map((shop, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    url: `${import.meta.env.SITE_URL || 'https://ebikelocal.com'}/shops/${city.state_slug}/${city.slug}/${shop.slug}/`,
    name: shop.name,
  })),
};
---

<BaseLayout
  title={`eBike Shops in ${city.name}, ${city.state_code} — Find Local Dealers | eBikeLocal`}
  description={`${shops.length} eBike ${shops.length === 1 ? 'shop' : 'shops'} in ${city.name}, ${city.state_code}${brandCounts.length > 0 ? ` — carrying ${brandCounts.slice(0, 3).map((b: any) => b.name).join(', ')}` : ''}. Ratings, hours, addresses, and brand data in one place.`}
  jsonLd={itemListSchema}
>
  <div class="mx-auto max-w-7xl px-(--spacing-page) py-8">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: 'Shops', href: '/shops/' },
      { label: city.state_name, href: `/shops/${Astro.params.stateSlug}/` },
      { label: city.name },
    ]} />

    <h1 class="mt-6 text-3xl font-extrabold text-surface-900 md:text-4xl">
      eBike Shops in {city.name}, {city.state_code}
    </h1>
    <p class="mt-2 text-lg text-surface-700">
      {shops.length} electric bike {shops.length === 1 ? 'shop' : 'shops'} in {city.name}.
    </p>

    {brandCounts.length > 0 && (
      <p class="mt-2 max-w-2xl text-surface-600 leading-relaxed">
        {city.name} dealers carry {brandListText}. Browse the full list below or filter by brand to find a shop near you.
      </p>
    )}

    <!-- Map -->
    {mapPins.length > 0 && (
      <div class="mt-6">
        <MultiPinMap
          pins={mapPins}
          centerLat={city.latitude ? Number(city.latitude) : undefined}
          centerLng={city.longitude ? Number(city.longitude) : undefined}
        />
      </div>
    )}

    <!-- Brands in city -->
    {brandCounts.length > 0 && (
      <section class="mt-8">
        <h2 class="text-lg font-bold text-surface-900">Brands Available in {city.name}</h2>
        <p class="mt-1 text-sm text-surface-600">Use these chips to filter shops by brand.</p>
        <div class="mt-3 flex flex-wrap gap-2" id="brand-filter-chips">
          <button
            type="button"
            class="brand-filter-chip rounded-full border border-brand-300 bg-brand-50 px-3 py-1 text-sm font-medium text-brand-700"
            data-brand=""
          >
            All shops ({shops.length})
          </button>
          {brandCounts.map((b) => (
            <button
              type="button"
              class="brand-filter-chip rounded-full border border-surface-200 px-3 py-1 text-sm font-medium text-surface-900 transition-colors hover:border-brand-600 hover:text-brand-600"
              data-brand={b.name}
            >
              {b.name} ({b.count})
            </button>
          ))}
        </div>
      </section>
    )}

    <!-- Shop list -->
    <section class="mt-8">
      <h2 class="text-lg font-bold text-surface-900">All Shops</h2>
      <p id="city-shop-count" class="sr-only" aria-live="polite" aria-atomic="true"></p>
      <div class="mt-4 space-y-3" id="city-shop-list">
        {shops.map((shop) => (
          <div class="city-shop-item" data-brands={(shop.brand_names || []).join('||').toLowerCase()}>
            <ShopCard
              name={shop.name}
              slug={shop.slug}
              stateSlug={Astro.params.stateSlug}
              citySlug={city.slug}
              address={shop.address_line1 || ''}
              city={shop.city}
              stateCode={shop.state_code}
              rating={shop.google_rating ? Number(shop.google_rating) : null}
              reviewCount={shop.google_review_count}
              brands={shop.brand_names || []}
              services={shop.services || []}
              featuredImageUrl={shop.featured_image_url}
              isEbikeSpecialist={shop.is_ebike_specialist}
            />
          </div>
        ))}
      </div>
      <p id="city-shop-filter-empty" class="mt-4 hidden rounded-lg border border-surface-200 bg-surface-50 px-4 py-3 text-sm text-surface-700">
        No shops in this city are tagged with that brand yet.
      </p>
    </section>

    <!-- State law callout -->
    {(() => {
      // We need state law data — fetch inline
      return null; // Populated via state prop passed from getStaticPaths
    })()}
    <section class="mt-10 rounded-lg border border-surface-200 bg-surface-50 p-5">
      <h2 class="text-sm font-bold uppercase tracking-wide text-surface-700">eBike Laws in {city.state_name}</h2>
      <p class="mt-1 text-surface-900">
        Check the rules for riding eBikes in {city.state_name} — class restrictions, helmet requirements, and trail access.
      </p>
      <a
        href={`/guides/ebike-laws/${Astro.params.stateSlug}/`}
        class="mt-2 inline-block text-sm font-medium text-brand-600 hover:underline"
      >
        Read {city.state_name} eBike Law Guide →
      </a>
    </section>

    <!-- Nearby cities -->
    {nearbyCitiesSorted.length > 0 && (
      <section class="mt-12">
        <h2 class="text-lg font-bold text-surface-900">Nearby Cities with eBike Shops</h2>
        <div class="mt-4 grid gap-3 sm:grid-cols-2 md:grid-cols-4">
          {nearbyCitiesSorted.map((nc: any) => (
            <a
              href={`/shops/${nc.state_slug}/${nc.slug}/`}
              class="rounded-lg border border-surface-200 px-4 py-3 text-sm transition-colors hover:border-brand-600 hover:bg-brand-50"
            >
              <span class="font-medium text-surface-900">{nc.name}</span>
              <span class="ml-1 text-surface-700">
                ({nc.shop_count})
                {nc.distance_miles != null ? ` • ${Math.round(Number(nc.distance_miles))} mi` : ''}
              </span>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Buying guides cross-link -->
    <section class="mt-10 rounded-xl border border-surface-100 bg-surface-50 p-5">
      <h2 class="text-sm font-bold text-surface-800 mb-3">eBike Buying Resources</h2>
      <div class="flex flex-wrap gap-x-6 gap-y-2 text-sm">
        {[
          { title: 'How to Choose an eBike', href: '/guides/how-to-choose-an-ebike/' },
          { title: 'Best eBikes 2026', href: '/best/' },
          { title: 'Best Under $1,500', href: '/best/best-ebikes-under-1500/' },
          { title: 'Best Commuter eBikes', href: '/best/best-commuter-ebikes/' },
          { title: 'Compare All Brands', href: '/brands/' },
        ].map(l => (
          <a href={l.href} class="text-brand-600 hover:underline">{l.title} →</a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  const chips = Array.from(document.querySelectorAll<HTMLButtonElement>('.brand-filter-chip'));
  const shopItems = Array.from(document.querySelectorAll<HTMLElement>('.city-shop-item'));
  const emptyState = document.getElementById('city-shop-filter-empty');
  const liveRegion = document.getElementById('city-shop-count');

  function setActiveChip(activeBrand: string) {
    chips.forEach((chip) => {
      const isActive = (chip.dataset.brand || '') === activeBrand;
      chip.classList.toggle('border-brand-300', isActive);
      chip.classList.toggle('bg-brand-50', isActive);
      chip.classList.toggle('text-brand-700', isActive);
      chip.classList.toggle('border-surface-200', !isActive);
      chip.classList.toggle('bg-white', !isActive);
      chip.classList.toggle('text-surface-900', !isActive);
    });
  }

  function filterShopsByBrand(rawBrand: string) {
    const brand = rawBrand.trim().toLowerCase();
    let visible = 0;
    shopItems.forEach((item) => {
      const brands = item.dataset.brands || '';
      const match = !brand || brands.includes(brand);
      item.style.display = match ? '' : 'none';
      if (match) visible += 1;
    });
    emptyState?.classList.toggle('hidden', visible > 0);
    if (liveRegion) {
      liveRegion.textContent = brand
        ? `Showing ${visible} shop${visible !== 1 ? 's' : ''} carrying ${rawBrand.trim()}`
        : `Showing all ${visible} shop${visible !== 1 ? 's' : ''}`;
    }
  }

  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      const brand = chip.dataset.brand || '';
      setActiveChip(brand);
      filterShopsByBrand(brand);
    });
  });
</script>
