---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/ui/Breadcrumb.astro';
import RatingStars from '@components/ui/RatingStars.astro';
import MapEmbed from '@components/ui/MapEmbed.astro';
import ServiceTag from '@components/ui/ServiceTag.astro';
import CTAButton from '@components/ui/CTAButton.astro';
import BikeStoreSchema from '@components/seo/BikeStoreSchema.astro';
import sql from '@lib/neon';
import {
  buildShopAboutText,
  formatShopWebsiteLink,
  getOpeningHoursRows,
  humanizeShopAttribute,
  truncateForMetaDescription,
} from '@lib/shopDisplay';

export async function getStaticPaths() {
  const shops = await sql`
    SELECT s.slug as shop_slug, s.city, s.state_code,
           c.slug as city_slug, st.slug as state_slug
    FROM shops s
    JOIN cities c ON c.name = s.city AND c.state_code = s.state_code
    JOIN states st ON st.code = s.state_code
  WHERE (s.google_business_status IS NULL OR s.google_business_status != 'CLOSED_PERMANENTLY')
    AND COALESCE(s.listing_status, 'active') = 'active'
  `;

  return shops.map((s) => ({
    params: {
      stateSlug: s.state_slug,
      citySlug: s.city_slug,
      shopSlug: s.shop_slug,
    },
  }));
}

const { stateSlug, citySlug, shopSlug } = Astro.params;

const [shop] = await sql`
  SELECT s.*, st.name as state_name, st.slug as state_slug
  FROM shops s
  JOIN states st ON st.code = s.state_code
  WHERE s.slug = ${shopSlug}
    AND COALESCE(s.listing_status, 'active') = 'active'
  LIMIT 1
`;

if (!shop) return Astro.redirect('/404');

const brands = await sql`
  SELECT b.name, b.slug, b.logo_url, b.affiliate_program_url, sb.dealer_tier
  FROM shop_brands sb
  JOIN brands b ON b.id = sb.brand_id
  WHERE sb.shop_id = ${shop.id}
  ORDER BY b.name
`;

const nearbyShops = await sql`
  SELECT s.name, s.slug, s.google_rating, s.address_line1,
         c.slug as city_slug, st.slug as state_slug
  FROM shops s
  JOIN cities c ON c.name = s.city AND c.state_code = s.state_code
  JOIN states st ON st.code = s.state_code
  WHERE s.city = ${shop.city} AND s.state_code = ${shop.state_code}
    AND s.id != ${shop.id}
    AND (s.google_business_status IS NULL OR s.google_business_status != 'CLOSED_PERMANENTLY')
    AND COALESCE(s.listing_status, 'active') = 'active'
  ORDER BY s.google_rating DESC NULLS LAST
  LIMIT 5
`;

const reviews = await sql`
  SELECT * FROM reviews
  WHERE shop_id = ${shop.id}
  ORDER BY created_at DESC
  LIMIT 10
`;

/** Google Places stores photo *resource names* in `photos`, not usable as img src until resolved to https URLs (see scripts/populate-shop-images.mjs). */
const isHttpImageUrl = (u: unknown): u is string =>
  typeof u === 'string' && /^https?:\/\//i.test(u.trim());

const heroImageUrl = isHttpImageUrl(shop.featured_image_url) ? shop.featured_image_url.trim() : null;
const galleryPhotoUrls = (shop.photos ?? []).filter(isHttpImageUrl).map((u: string) => u.trim());
const schemaImageUrl = heroImageUrl ?? galleryPhotoUrls[0] ?? null;

const brandNames = brands.map((b) => b.name);
const formatDealerTier = (tier: string | null | undefined) => {
  if (!tier) return null;
  const normalized = tier.toLowerCase().trim();
  if (normalized === 'authorized_online' || normalized === 'authorized') return 'Authorized';
  return tier.replace(/_/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());
};
const aboutText = buildShopAboutText({
  name: shop.name,
  city: shop.city,
  stateCode: shop.state_code,
  editorialDescription: shop.description,
  descriptionGenerated: shop.description_generated,
  isEbikeSpecialist: !!shop.is_ebike_specialist,
  services: shop.services,
  brandNames,
  rating: shop.google_rating ? Number(shop.google_rating) : null,
  reviewCount: shop.google_review_count ? Number(shop.google_review_count) : null,
  openingHours: shop.opening_hours,
});
const metaDescription = truncateForMetaDescription(aboutText);
const hoursRows = getOpeningHoursRows(shop.opening_hours);
const websiteLink = formatShopWebsiteLink(shop.website);
const shopTypeLabel = humanizeShopAttribute(shop.shop_type);
const priceTierLabel = humanizeShopAttribute(shop.price_tier);
const email = (shop.email ?? '').trim() || null;
const hasQuickContact = !!(shop.phone || websiteLink || email);
---

<BaseLayout
  title={`${shop.name} — eBike Shop in ${shop.city}, ${shop.state_code} | eBikeLocal`}
  description={metaDescription}
>
  <BikeStoreSchema
    name={shop.name}
    description={aboutText}
    address={{
      street: shop.address_line1 || '',
      city: shop.city,
      state: shop.state,
      zip: shop.zip,
    }}
    latitude={Number(shop.latitude)}
    longitude={Number(shop.longitude)}
    phone={shop.phone}
    website={shop.website}
    rating={shop.google_rating ? Number(shop.google_rating) : null}
    reviewCount={shop.google_review_count}
    imageUrl={schemaImageUrl}
  />

  <div class="mx-auto max-w-7xl px-(--spacing-page) py-8">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: 'Shops', href: '/shops/' },
      { label: shop.state_name, href: `/shops/${stateSlug}/` },
      { label: shop.city, href: `/shops/${stateSlug}/${citySlug}/` },
      { label: shop.name },
    ]} />

    <div class="mt-6 grid gap-8 lg:grid-cols-3">
      <!-- Main content -->
      <div class="lg:col-span-2">
        <h1 class="text-3xl font-extrabold text-surface-900">{shop.name}</h1>

        <div class="mt-2 flex flex-wrap items-center gap-3">
          {shop.google_rating && (
            <RatingStars rating={Number(shop.google_rating)} reviewCount={shop.google_review_count} />
          )}
          {shop.is_ebike_specialist && (
            <span class="rounded-full bg-accent-500/10 px-2.5 py-1 text-xs font-medium text-accent-600">
              eBike Specialist
            </span>
          )}
        </div>

        {(hasQuickContact || shopTypeLabel || priceTierLabel) && (
          <div class="mt-4 space-y-2">
            {hasQuickContact && (
              <p class="flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-surface-700">
                {shop.phone && (
                  <a href={`tel:${String(shop.phone).replace(/\s/g, '')}`} class="font-medium text-brand-600 hover:underline">
                    {shop.phone}
                  </a>
                )}
                {shop.phone && (websiteLink || email) && <span class="text-surface-300" aria-hidden="true">·</span>}
                {websiteLink && (
                  <a
                    href={websiteLink.href}
                    target="_blank"
                    rel="nofollow noopener"
                    class="font-medium text-brand-600 hover:underline"
                    title={websiteLink.href}
                  >
                    {websiteLink.label}
                  </a>
                )}
                {websiteLink && email && <span class="text-surface-300" aria-hidden="true">·</span>}
                {email && (
                  <a href={`mailto:${email}`} class="font-medium text-brand-600 hover:underline break-all">
                    {email}
                  </a>
                )}
              </p>
            )}
            {(shopTypeLabel || priceTierLabel) && (
              <p class="flex flex-wrap gap-x-3 gap-y-1 text-sm text-surface-600">
                {shopTypeLabel && <span>Store: {shopTypeLabel}</span>}
                {shopTypeLabel && priceTierLabel && <span class="text-surface-300" aria-hidden="true">·</span>}
                {priceTierLabel && <span>Price: {priceTierLabel}</span>}
              </p>
            )}
          </div>
        )}

        {heroImageUrl && (
          <div class="mt-6 overflow-hidden rounded-lg border border-surface-200 bg-surface-50">
            <img
              src={heroImageUrl}
              alt={`${shop.name} storefront, ${shop.city}, ${shop.state_code}`}
              class="max-h-[28rem] w-full object-cover"
              loading="eager"
              decoding="async"
            />
          </div>
        )}

        <p class="mt-4 text-surface-700 leading-relaxed">{aboutText}</p>

        <!-- Services -->
        {shop.services?.length > 0 && (
          <section class="mt-6">
            <h2 class="text-lg font-bold text-surface-900">Services</h2>
            <div class="mt-2 flex flex-wrap gap-2">
              {shop.services.map((service: string) => (
                <ServiceTag service={service} />
              ))}
            </div>
          </section>
        )}

        <!-- Brands carried -->
        {brands.length > 0 && (
          <section class="mt-8">
            <h2 class="text-lg font-bold text-surface-900">Brands Carried</h2>
            <div class="mt-3 space-y-3">
              {brands.map((brand) => (
                <div class="flex items-center justify-between rounded-lg border border-surface-200 p-3">
                  <a href={`/brands/${brand.slug}/`} class="flex items-center gap-3 font-medium text-surface-900 hover:text-brand-600">
                    {brand.logo_url && (
                      <img src={brand.logo_url} alt={`${brand.name} eBike logo`} class="h-8 w-8 object-contain" loading="lazy" />
                    )}
                    {brand.name}
                    {brand.name === 'Rad Power Bikes' && (
                      <span
                        class="inline-flex items-center gap-1 rounded bg-amber-50 px-1.5 py-0.5 text-xs text-amber-700 ring-1 ring-amber-200"
                        title="Dealer status may have changed — Rad Power Bikes filed Chapter 11 in Dec 2025"
                      >
                        ⚠️ Status update
                      </span>
                    )}
                    {formatDealerTier(brand.dealer_tier) && (
                      <span class="rounded bg-surface-100 px-1.5 py-0.5 text-xs text-surface-700">
                        {formatDealerTier(brand.dealer_tier)}
                      </span>
                    )}
                  </a>
                  {brand.affiliate_program_url && (
                    <CTAButton href={brand.affiliate_program_url} brandName={brand.name} variant="secondary" />
                  )}
                </div>
              ))}
            </div>
          </section>
        )}

        <!-- Reviews -->
        {reviews.length > 0 && (
          <section class="mt-8">
            <h2 class="text-lg font-bold text-surface-900">Reviews</h2>
            <div class="mt-3 space-y-4">
              {reviews.map((review) => (
                <div class="rounded-lg border border-surface-200 p-4">
                  <div class="flex items-center gap-2">
                    <span class="font-medium text-surface-900">{review.user_name || 'Anonymous'}</span>
                    <RatingStars rating={review.rating} size="sm" />
                  </div>
                  {review.review_text && (
                    <p class="mt-2 text-sm text-surface-700">{review.review_text}</p>
                  )}
                </div>
              ))}
            </div>
          </section>
        )}

        <!-- Photos (only entries already resolved to https URLs; raw Places names are not valid img src) -->
        {galleryPhotoUrls.length > 0 && (
          <section class="mt-8">
            <h2 class="text-lg font-bold text-surface-900">Photos</h2>
            <div class="mt-3 grid grid-cols-2 gap-2 md:grid-cols-3">
              {galleryPhotoUrls.map((url: string, idx: number) => (
                <img src={url} alt={`${shop.name} — photo ${idx + 1}, ${shop.city}, ${shop.state_code}`} class="rounded-lg object-cover aspect-square" loading="lazy" />
              ))}
            </div>
          </section>
        )}
      </div>

      <!-- Sidebar -->
      <aside class="space-y-6">
        <!-- Map -->
        {shop.latitude && shop.longitude && (
          <MapEmbed
            name={shop.name}
            latitude={Number(shop.latitude)}
            longitude={Number(shop.longitude)}
            googleMapsUrl={shop.google_maps_uri}
          />
        )}

        <!-- Contact info -->
        <div class="rounded-lg border border-surface-200 p-4 space-y-3">
          <h3 class="font-bold text-surface-900">Contact Info</h3>

          {(shop.is_verified || shop.is_partner || shop.is_claimed) && (
            <p class="flex flex-wrap gap-1.5 text-xs text-surface-600">
              {shop.is_verified && (
                <span class="rounded bg-emerald-50 px-2 py-0.5 font-medium text-emerald-800 ring-1 ring-emerald-200/80">Verified</span>
              )}
              {shop.is_partner && (
                <span class="rounded bg-brand-50 px-2 py-0.5 font-medium text-brand-800 ring-1 ring-brand-200/80">Partner</span>
              )}
              {shop.is_claimed && (
                <span class="rounded bg-surface-100 px-2 py-0.5 font-medium text-surface-800 ring-1 ring-surface-200">Claimed</span>
              )}
            </p>
          )}

          <dl class="text-sm text-surface-700 space-y-2">
            {shop.address_line1 && (
              <div>
                <dt class="text-xs font-medium uppercase tracking-wide text-surface-500">Address</dt>
                <dd class="mt-0.5">
                  {shop.address_line1}{shop.address_line2 ? `, ${shop.address_line2}` : ''}
                  <br />
                  {shop.city}, {shop.state_code} {shop.zip}
                  {shop.country && String(shop.country).trim() && String(shop.country).toUpperCase() !== 'US' && (
                    <><br />{String(shop.country).toUpperCase()}</>
                  )}
                </dd>
              </div>
            )}
            {shop.phone && (
              <div>
                <dt class="text-xs font-medium uppercase tracking-wide text-surface-500">Phone</dt>
                <dd class="mt-0.5">
                  <a href={`tel:${shop.phone.replace(/\s/g, '')}`} class="font-medium text-brand-600 hover:underline">
                    {shop.phone}
                  </a>
                </dd>
              </div>
            )}
            {email && (
              <div>
                <dt class="text-xs font-medium uppercase tracking-wide text-surface-500">Email</dt>
                <dd class="mt-0.5 break-all">
                  <a href={`mailto:${email}`} class="font-medium text-brand-600 hover:underline">
                    {email}
                  </a>
                </dd>
              </div>
            )}
            {websiteLink && (
              <div>
                <dt class="text-xs font-medium uppercase tracking-wide text-surface-500">Website</dt>
                <dd class="mt-0.5 break-all">
                  <a
                    href={websiteLink.href}
                    target="_blank"
                    rel="nofollow noopener"
                    class="font-medium text-brand-600 hover:underline"
                    title={websiteLink.href}
                  >
                    {websiteLink.href}
                  </a>
                </dd>
              </div>
            )}
            {shopTypeLabel && (
              <div>
                <dt class="text-xs font-medium uppercase tracking-wide text-surface-500">Store type</dt>
                <dd class="mt-0.5 text-surface-800">{shopTypeLabel}</dd>
              </div>
            )}
            {priceTierLabel && (
              <div>
                <dt class="text-xs font-medium uppercase tracking-wide text-surface-500">Price</dt>
                <dd class="mt-0.5 text-surface-800">{priceTierLabel}</dd>
              </div>
            )}
          </dl>

          <!-- Hours (Google Places regularOpeningHours.weekdayDescriptions) -->
          {hoursRows && (
            <div class="border-t border-surface-200 pt-3">
              <h4 class="text-sm font-semibold text-surface-900">Hours</h4>
              <div class="mt-1 text-sm text-surface-700 space-y-1">
                {hoursRows.map((row) => (
                  <div class="flex justify-between gap-3">
                    <span class="shrink-0 font-medium text-surface-800">{row.day}</span>
                    <span class="text-right tabular-nums">{row.hours}</span>
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>

        <!-- Nearby shops -->
        {nearbyShops.length > 0 && (
          <div class="rounded-lg border border-surface-200 p-4">
            <h3 class="font-bold text-surface-900">Nearby eBike Shops</h3>
            <div class="mt-3 space-y-2">
              {nearbyShops.map((ns) => (
                <a
                  href={`/shops/${ns.state_slug}/${ns.city_slug}/${ns.slug}/`}
                  class="block text-sm hover:text-brand-600 transition-colors"
                >
                  <span class="font-medium">{ns.name}</span>
                  {ns.google_rating && <span class="text-surface-700"> — {Number(ns.google_rating).toFixed(1)}★</span>}
                </a>
              ))}
            </div>
          </div>
        )}
      </aside>
    </div>
  </div>
</BaseLayout>
