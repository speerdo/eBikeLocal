---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/ui/Breadcrumb.astro';
import PageHeader from '@components/ui/PageHeader.astro';
import sql from '@lib/neon';

const states = await sql`
  SELECT code, name, slug, shop_count
  FROM states
  ORDER BY name
`;

const totalShops = states.reduce((sum, s) => sum + (s.shop_count || 0), 0);
const topStates = [...states].sort((a, b) => (b.shop_count || 0) - (a.shop_count || 0)).slice(0, 6);
---

<BaseLayout
  title="eBike Shop Directory — All 50 States"
  description={`Find eBike shops in every US state. ${totalShops > 0 ? totalShops.toLocaleString() + ' shops' : 'Thousands of shops'} listed with brand data, ratings, and contact info.`}
>
  <PageHeader
    eyebrow="Shop Directory"
    title="Find eBike Shops Near You"
    subtitle={`${totalShops > 0 ? totalShops.toLocaleString() + ' electric bike shops' : 'Thousands of shops'} across all 50 states — with brand data no other directory has.`}
    imageUrl="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=1200&q=70&auto=format&fit=crop"
  />

  <div class="mx-auto max-w-7xl page-x py-8">
    <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Shops' }]} />

    {topStates.length > 0 && totalShops > 0 && (
      <section class="mt-8">
        <h2 class="font-display text-lg font-bold text-surface-900">Most Active States</h2>
        <div class="mt-3 grid gap-3 sm:grid-cols-3 lg:grid-cols-6">
          {topStates.map(s => (
            <a
              href={`/shops/${s.slug}/`}
              class="card-hover flex flex-col items-center rounded-2xl border border-surface-200 bg-white py-4 text-center shadow-card"
            >
              <p class="font-display text-2xl font-extrabold text-brand-600">{s.shop_count}</p>
              <p class="mt-0.5 text-sm font-semibold text-surface-900">{s.name}</p>
              <p class="text-xs text-surface-400">shops</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="mt-10">
      <div class="mb-4 flex items-end justify-between">
        <h2 class="font-display text-lg font-bold text-surface-900">eBike Riding Moments</h2>
        <span class="text-xs font-semibold uppercase tracking-wide text-surface-400">Across city and trail</span>
      </div>
      <div class="grid gap-4 md:grid-cols-3">
        {[
          {
            id: '15009884',
            alt: 'Rider on an electric bike along a coastal road',
            caption: 'Commute-ready rides for daily miles',
          },
          {
            id: '15009950',
            alt: 'Two people riding electric bikes on an open road',
            caption: 'Weekend routes and group rides',
          },
          {
            id: '15009961',
            alt: 'Person riding an electric bike on a wooded trail',
            caption: 'Trail-capable eBikes for adventure',
          },
        ].map((photo) => (
          <div class="group overflow-hidden rounded-2xl border border-surface-200 bg-white shadow-card">
            <div class="relative h-52 overflow-hidden">
              <img
                src={`https://images.pexels.com/photos/${photo.id}/pexels-photo-${photo.id}.jpeg?auto=compress&cs=tinysrgb&w=900&dpr=1`}
                alt={photo.alt}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
              <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-night-900/40 via-transparent to-transparent"></div>
            </div>
            <p class="px-4 py-3 text-sm font-medium text-surface-700">{photo.caption}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="mt-10">
      <h2 class="font-display text-lg font-bold text-surface-900">Browse by State</h2>
      <div class="mt-4 grid gap-2 grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5">
        {states.map((state) => (
          <a
            href={`/shops/${state.slug}/`}
            class="group flex items-center justify-between rounded-xl border border-surface-200 bg-white px-4 py-3 transition-all hover:border-brand-300 hover:bg-brand-50 hover:shadow-sm"
          >
            <span class="font-medium text-surface-800 group-hover:text-brand-700 transition-colors text-sm">{state.name}</span>
            {state.shop_count > 0 ? (
              <span class="rounded-full bg-surface-100 px-2 py-0.5 text-xs font-medium text-surface-500 group-hover:bg-brand-100 group-hover:text-brand-600 transition-colors">
                {state.shop_count}
              </span>
            ) : (
              <span class="text-xs text-surface-300">—</span>
            )}
          </a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
