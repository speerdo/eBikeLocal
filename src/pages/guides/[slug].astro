---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/ui/Breadcrumb.astro';
import FAQSchema from '@components/seo/FAQSchema.astro';
import { getSiteStats } from '@lib/siteStats';

export async function getStaticPaths() {
  const entries = await getCollection('guides');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const { shopCount } = await getSiteStats();

const { title, description, publishedAt, updatedAt, heroImage, category, tags, faqs } = entry.data;

// Format date
const dateStr = (updatedAt ?? publishedAt).toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});

// Category label
const categoryLabel: Record<string, string> = {
  'buying-guide': 'Buying Guide',
  'laws': 'Laws & Regulations',
  'education': 'eBike Education',
  'news': 'News & Updates',
};

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: publishedAt.toISOString(),
  dateModified: (updatedAt ?? publishedAt).toISOString(),
  image: heroImage || undefined,
  mainEntityOfPage: `${import.meta.env.SITE_URL || 'https://ebikelocal.com'}/guides/${entry.id}/`,
  author: {
    '@type': 'Organization',
    name: 'eBikeLocal',
  },
  publisher: {
    '@type': 'Organization',
    name: 'eBikeLocal',
  },
};
---

<BaseLayout
  title={`${title} | eBikeLocal`}
  description={description}
  ogImage={heroImage}
  jsonLd={articleSchema}
>

  <!-- Hero header -->
  <section class="relative overflow-hidden bg-night-900">
    {heroImage && (
      <div class="absolute inset-0 pointer-events-none">
        <img src={heroImage} alt="" class="h-full w-full object-cover opacity-20" loading="eager" />
        <div class="absolute inset-0 bg-gradient-to-r from-night-900 via-night-900/85 to-night-900/50"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-night-900/60 to-transparent"></div>
      </div>
    )}
    <div class="absolute inset-0 bg-circuit pointer-events-none opacity-60"></div>
    <div class="absolute -top-24 right-0 h-72 w-72 rounded-full bg-brand-400/8 blur-3xl pointer-events-none"></div>

    <div class="relative mx-auto max-w-4xl page-x py-12 md:py-16">
      <Breadcrumb items={[
        { label: 'Home', href: '/' },
        { label: 'Guides', href: '/guides/' },
        { label: title },
      ]} />

      <div class="mt-5">
        <div class="mb-4 w-10 h-[3px] rounded-full bg-gradient-to-r from-brand-400 to-electric-400"></div>
        {category && (
          <span class="inline-block text-[11px] font-700 uppercase tracking-widest text-brand-400 mb-3">
            {categoryLabel[category] ?? category}
          </span>
        )}
        <h1 class="font-display text-3xl font-700 tracking-tight text-white md:text-4xl lg:text-[2.5rem] leading-[1.1]">
          {title}
        </h1>
        <p class="mt-3 max-w-2xl text-lg text-night-300 leading-relaxed">{description}</p>
        <p class="mt-4 text-xs text-night-500">Updated {dateStr}</p>
      </div>
    </div>
  </section>

  <!-- Article body -->
  <div class="mx-auto max-w-4xl page-x py-10 md:py-14">
    <div class="flex gap-10">

      <!-- Main content -->
      <article class="min-w-0 flex-1 prose prose-slate max-w-none
        prose-headings:font-display prose-headings:font-700 prose-headings:tracking-tight
        prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4 prose-h2:text-surface-900
        prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3 prose-h3:text-surface-900
        prose-p:text-surface-700 prose-p:leading-relaxed prose-p:mb-4
        prose-a:text-brand-600 prose-a:font-500 prose-a:no-underline [&_a:hover]:underline
        prose-strong:text-surface-900 prose-strong:font-700
        prose-ul:text-surface-700 prose-ol:text-surface-700
        prose-li:mb-1.5
        prose-table:text-sm
        prose-th:bg-surface-50 prose-th:font-600 prose-th:text-surface-800
        prose-td:text-surface-700
        prose-blockquote:border-l-brand-400 prose-blockquote:bg-brand-50/50 prose-blockquote:rounded-r-lg prose-blockquote:py-1
        prose-code:text-brand-700 prose-code:bg-brand-50 prose-code:px-1.5 prose-code:rounded
        prose-hr:border-surface-200
        prose-figure:my-0 prose-img:rounded-xl prose-img:shadow-card
      ">
        <Content />
      </article>

      <!-- Table of contents — desktop only -->
      {headings.filter(h => h.depth <= 2).length > 2 && (
        <aside class="hidden xl:block w-56 shrink-0">
          <div class="sticky top-24">
            <p class="text-xs font-700 uppercase tracking-widest text-surface-500 mb-3">On This Page</p>
            <nav>
              <ul class="space-y-1.5 text-sm">
                {headings
                  .filter(h => h.depth <= 2)
                  .map(h => (
                    <li>
                      <a
                        href={`#${h.slug}`}
                        class={`block text-surface-600 hover:text-brand-600 transition-colors leading-snug ${h.depth === 2 ? '' : 'pl-3 text-surface-500 text-xs'}`}
                      >
                        {h.text}
                      </a>
                    </li>
                  ))
                }
              </ul>
            </nav>
          </div>
        </aside>
      )}
    </div>

    <!-- Tags -->
    {tags && tags.length > 0 && (
      <div class="mt-10 flex flex-wrap gap-2 border-t border-surface-100 pt-6">
        {tags.map(tag => (
          <span class="rounded-full bg-surface-100 px-3 py-1 text-xs text-surface-600">
            {tag}
          </span>
        ))}
      </div>
    )}

    <!-- CTA -->
    <div class="mt-10 rounded-2xl bg-night-900 p-7 relative overflow-hidden">
      <div class="absolute inset-0 bg-circuit opacity-60 pointer-events-none"></div>
      <div class="absolute top-0 right-0 h-40 w-40 rounded-full bg-brand-400/8 blur-2xl pointer-events-none"></div>
      <div class="relative">
        <div class="mb-3 w-8 h-[3px] rounded-full bg-gradient-to-r from-brand-400 to-electric-400"></div>
        <h3 class="font-display text-lg font-700 text-white">Find eBike Dealers Near You</h3>
        <p class="mt-1.5 text-sm text-night-400 max-w-md">
          Search our directory of {shopCount.toLocaleString()} shops across the US. Filter by brand, see ratings, and get directions.
        </p>
        <a href="/shops/" class="btn-volt inline-flex mt-4 rounded-xl px-6 py-2.5 text-sm">
          Find a Shop →
        </a>
      </div>
    </div>

    <!-- Related guides -->
    <div class="mt-10">
      <h3 class="text-sm font-700 uppercase tracking-widest text-surface-500 mb-4">More Guides</h3>
      <div class="flex flex-wrap gap-3">
        {[
          { title: 'eBike Classes Explained', href: '/guides/ebike-classes-explained/' },
          { title: 'How to Choose an eBike', href: '/guides/how-to-choose-an-ebike/' },
          { title: 'eBike Tax Credit 2026', href: '/guides/ebike-tax-credit-2026/' },
          { title: 'eBike Laws by State', href: '/guides/ebike-laws-by-state/' },
          { title: 'What to Look for in a Shop', href: '/guides/what-to-look-for-in-an-ebike-shop/' },
        ]
        .filter(g => !Astro.url.pathname.includes(g.href.replace('/guides/', '').replace('/', '')))
        .slice(0, 4)
        .map(g => (
          <a href={g.href} class="rounded-xl border border-surface-200 bg-white px-4 py-2.5 text-sm font-500 text-surface-700 hover:border-brand-200 hover:text-brand-700 transition-colors shadow-card">
            {g.title}
          </a>
        ))}
      </div>
    </div>

    <!-- Cross-links: buying guides + top brands -->
    <div class="mt-8 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-surface-100 bg-surface-50 p-5">
        <h3 class="text-sm font-700 text-surface-800 mb-3">eBike Buying Guides</h3>
        <ul class="space-y-2 text-sm">
          {[
            { title: 'Best eBikes Under $1,000', href: '/best/best-ebikes-under-1000/' },
            { title: 'Best eBikes Under $1,500', href: '/best/best-ebikes-under-1500/' },
            { title: 'Best Commuter eBikes', href: '/best/best-commuter-ebikes/' },
            { title: 'Best Mountain eBikes', href: '/best/best-mountain-ebikes/' },
          ].map(g => (
            <li><a href={g.href} class="text-brand-600 hover:underline">{g.title} →</a></li>
          ))}
        </ul>
      </div>
      <div class="rounded-xl border border-surface-100 bg-surface-50 p-5">
        <h3 class="text-sm font-700 text-surface-800 mb-3">Top eBike Brands</h3>
        <ul class="space-y-2 text-sm">
          {[
            { title: 'Aventon eBikes', href: '/brands/aventon/' },
            { title: 'Trek Electric Bikes', href: '/brands/trek/' },
            { title: 'Specialized eBikes', href: '/brands/specialized/' },
            { title: 'Lectric eBikes', href: '/brands/lectric/' },
          ].map(b => (
            <li><a href={b.href} class="text-brand-600 hover:underline">{b.title} →</a></li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</BaseLayout>

{faqs && faqs.length > 0 && <FAQSchema items={faqs} />}
