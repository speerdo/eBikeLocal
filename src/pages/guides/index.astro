---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/ui/Breadcrumb.astro';
import PageHeader from '@components/ui/PageHeader.astro';

const guides = [
  { title: 'eBike Tax Credit 2026', slug: 'ebike-tax-credit-2026', tag: 'Tax & Finance', emoji: '💰', description: 'Everything you need to know about the federal eBike tax credit — eligibility, amount, and how to claim it.' },
  { title: 'eBike Laws by State', slug: 'ebike-laws-by-state', tag: 'Laws', emoji: '⚖️', description: 'Class 1, 2, and 3 rules, helmet requirements, trail access, and rebate programs in all 50 states.' },
  { title: 'eBike Classes Explained', slug: 'ebike-classes-explained', tag: 'Beginner Guide', emoji: '📋', description: 'Class 1 vs 2 vs 3 — what the numbers mean, where you can ride, and which is right for you.' },
  { title: 'How to Choose an eBike', slug: 'how-to-choose-an-ebike', tag: 'Buying Guide', emoji: '🎯', description: 'A step-by-step framework for choosing the right electric bike for your needs, budget, and riding style.' },
  { title: 'What to Look for in an eBike Shop', slug: 'what-to-look-for-in-an-ebike-shop', tag: 'Shopping Advice', emoji: '🏪', description: 'How to evaluate a local eBike dealer — test rides, service quality, parts availability, and warranty support.' },
];
---

<BaseLayout
  title="eBike Guides — Electric Bike Tips, Laws & Expert Advice"
  description="Expert eBike guides covering tax credits, state laws, buying advice, class explanations, and more. Updated for 2026."
>
  <PageHeader
    eyebrow="Guides & Resources"
    title="eBike Guides"
    subtitle="Expert content on eBike laws, tax credits, buying advice, and everything you need to ride smarter."
  />

  <div class="mx-auto max-w-7xl page-x py-8">
    <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Guides' }]} />

    <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {guides.map((guide) => (
        <a
          href={`/guides/${guide.slug}/`}
          class="group card-hover flex flex-col rounded-2xl border border-surface-200 bg-white p-6 shadow-card"
        >
          <div class="flex items-center gap-3">
            <span class="text-3xl">{guide.emoji}</span>
            <span class="rounded-full bg-brand-50 px-2.5 py-0.5 text-xs font-semibold text-brand-600 ring-1 ring-brand-100">
              {guide.tag}
            </span>
          </div>
          <h2 class="mt-4 font-display text-lg font-bold text-surface-900 group-hover:text-brand-600 transition-colors">
            {guide.title}
          </h2>
          <p class="mt-2 flex-1 text-sm leading-relaxed text-surface-600">{guide.description}</p>
          <div class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-brand-600 group-hover:gap-2 transition-all">
            Read guide
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        </a>
      ))}
    </div>

    <!-- State laws grid -->
    <div class="mt-12 rounded-2xl border border-surface-200 bg-surface-50 p-6">
      <h2 class="font-display text-xl font-bold text-surface-900">eBike Laws by State</h2>
      <p class="mt-1 text-sm text-surface-600">Browse state-specific eBike rules, class restrictions, and rebate programs.</p>
      <a href="/guides/ebike-laws-by-state/" class="mt-3 inline-flex items-center gap-1 text-sm font-semibold text-brand-600 hover:gap-2 transition-all">
        View all 50 states
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</BaseLayout>
