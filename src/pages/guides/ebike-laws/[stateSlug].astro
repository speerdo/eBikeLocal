---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/ui/Breadcrumb.astro';
import FAQSchema from '@components/seo/FAQSchema.astro';
import sql from '@lib/neon';

export async function getStaticPaths() {
  const states = await sql`SELECT code, name, slug FROM states`;
  return states.map((s) => ({ params: { stateSlug: s.slug }, props: { state: s } }));
}

const { state } = Astro.props;

const [stateData] = await sql`SELECT * FROM states WHERE code = ${state.code} LIMIT 1`;

const faqItems = [
  {
    question: `Are eBikes legal in ${stateData.name}?`,
    answer: stateData.ebike_law_summary || `Yes, eBikes are legal in ${stateData.name}. They follow the standard 3-class eBike system.`,
  },
  {
    question: `Do I need a helmet to ride an eBike in ${stateData.name}?`,
    answer: stateData.helmet_required
      ? `Yes, ${stateData.name} requires helmets for eBike riders${stateData.min_age ? ` under age ${stateData.min_age}` : ''}.`
      : `${stateData.name} does not have a universal helmet requirement for eBike riders, though it is strongly recommended.`,
  },
  {
    question: `Do I need to register an eBike in ${stateData.name}?`,
    answer: stateData.registration_required
      ? `Yes, some or all eBikes in ${stateData.name} require registration.`
      : `No, eBikes do not require registration in ${stateData.name} as long as they meet the state's eBike definition (typically under 750W motor and speed limits).`,
  },
  {
    question: `What classes of eBikes are allowed in ${stateData.name}?`,
    answer: stateData.ebike_classes_allowed || `${stateData.name} allows Class 1, 2, and 3 eBikes.`,
  },
];
---

<BaseLayout
  title={`${stateData.name} eBike Laws 2026 — Class Rules, Helmets & Where to Ride`}
  description={`Complete guide to eBike laws in ${stateData.name}. Class 1, 2, and 3 rules, helmet requirements, trail access, and rebate programs.`}
>
  <FAQSchema items={faqItems} />

  <div class="mx-auto max-w-4xl px-(--spacing-page) py-8">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: 'Guides', href: '/guides/' },
      { label: 'eBike Laws by State', href: '/guides/ebike-laws-by-state/' },
      { label: stateData.name },
    ]} />

    <h1 class="mt-6 text-3xl font-extrabold text-surface-900 md:text-4xl">
      {stateData.name} eBike Laws (2026)
    </h1>
    <p class="mt-3 text-lg text-surface-700">{stateData.ebike_law_summary}</p>

    <!-- Quick reference card -->
    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <div class="rounded-lg border border-surface-200 p-4 text-center">
        <p class="text-2xl">{stateData.helmet_required ? '⛑️' : '✅'}</p>
        <p class="mt-1 font-semibold text-surface-900">Helmet</p>
        <p class="text-sm text-surface-700">{stateData.helmet_required ? `Required${stateData.min_age ? ` under ${stateData.min_age}` : ''}` : 'Not required'}</p>
      </div>
      <div class="rounded-lg border border-surface-200 p-4 text-center">
        <p class="text-2xl">📋</p>
        <p class="mt-1 font-semibold text-surface-900">Registration</p>
        <p class="text-sm text-surface-700">{stateData.registration_required ? 'Required' : 'Not required'}</p>
      </div>
      <div class="rounded-lg border border-surface-200 p-4 text-center">
        <p class="text-2xl">🚲</p>
        <p class="mt-1 font-semibold text-surface-900">Classes Allowed</p>
        <p class="text-sm text-surface-700">{stateData.ebike_classes_allowed || '1, 2, 3'}</p>
      </div>
      <div class="rounded-lg border border-surface-200 p-4 text-center">
        <p class="text-2xl">🔞</p>
        <p class="mt-1 font-semibold text-surface-900">Min Age</p>
        <p class="text-sm text-surface-700">{stateData.min_age ? `${stateData.min_age}+` : 'No minimum'}</p>
      </div>
    </div>

    <!-- Class rules -->
    <section class="mt-10">
      <h2 class="text-xl font-bold text-surface-900">eBike Class Rules in {stateData.name}</h2>
      <div class="mt-4 overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-surface-50 text-left">
            <tr>
              <th class="border border-surface-200 px-3 py-2 font-semibold">Class</th>
              <th class="border border-surface-200 px-3 py-2 font-semibold">Pedal Assist</th>
              <th class="border border-surface-200 px-3 py-2 font-semibold">Throttle</th>
              <th class="border border-surface-200 px-3 py-2 font-semibold">Max Speed</th>
              <th class="border border-surface-200 px-3 py-2 font-semibold">Where Allowed</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="border border-surface-200 px-3 py-2 font-medium">Class 1</td>
              <td class="border border-surface-200 px-3 py-2">Up to 20 mph</td>
              <td class="border border-surface-200 px-3 py-2">No</td>
              <td class="border border-surface-200 px-3 py-2">20 mph</td>
              <td class="border border-surface-200 px-3 py-2">Most bike paths and trails</td>
            </tr>
            <tr class="bg-surface-50">
              <td class="border border-surface-200 px-3 py-2 font-medium">Class 2</td>
              <td class="border border-surface-200 px-3 py-2">Up to 20 mph</td>
              <td class="border border-surface-200 px-3 py-2">Yes (20 mph max)</td>
              <td class="border border-surface-200 px-3 py-2">20 mph</td>
              <td class="border border-surface-200 px-3 py-2">Most bike paths; some trail restrictions</td>
            </tr>
            <tr>
              <td class="border border-surface-200 px-3 py-2 font-medium">Class 3</td>
              <td class="border border-surface-200 px-3 py-2">Up to 28 mph</td>
              <td class="border border-surface-200 px-3 py-2">Varies</td>
              <td class="border border-surface-200 px-3 py-2">28 mph</td>
              <td class="border border-surface-200 px-3 py-2">Roads and bike lanes only</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Rebate programs -->
    {stateData.rebate_programs && Array.isArray(stateData.rebate_programs) && stateData.rebate_programs.length > 0 && (
      <section class="mt-10">
        <h2 class="text-xl font-bold text-surface-900">eBike Rebate Programs in {stateData.name}</h2>
        <div class="mt-4 space-y-3">
          {stateData.rebate_programs.map((p: any) => (
            <div class="rounded-lg border border-surface-200 p-4">
              <h3 class="font-semibold text-surface-900">{p.name}</h3>
              {p.amount && <p class="text-sm font-medium text-accent-600 mt-1">Up to {p.amount}</p>}
              {p.eligibility && <p class="text-sm text-surface-700 mt-1">{p.eligibility}</p>}
              {p.url && <a href={p.url} target="_blank" rel="noopener" class="mt-2 inline-block text-sm text-brand-600 hover:underline">Learn more →</a>}
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- FAQ -->
    <section class="mt-10">
      <h2 class="text-xl font-bold text-surface-900">Frequently Asked Questions</h2>
      <div class="mt-4 space-y-4">
        {faqItems.map((item) => (
          <div class="rounded-lg border border-surface-200 p-5">
            <h3 class="font-semibold text-surface-900">{item.question}</h3>
            <p class="mt-2 text-sm text-surface-700">{item.answer}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Find local shops -->
    <div class="mt-10 rounded-lg bg-brand-50 p-6">
      <h2 class="text-lg font-bold text-surface-900">Find eBike Shops in {stateData.name}</h2>
      <p class="mt-1 text-sm text-surface-700">Browse local dealers, compare brands, and find shops near you.</p>
      <a href={`/shops/${stateData.slug}/`} class="mt-3 inline-block rounded-lg bg-brand-600 px-5 py-2.5 text-sm font-semibold text-white hover:bg-brand-700 transition-colors">
        Browse {stateData.name} Shops →
      </a>
    </div>
  </div>
</BaseLayout>
