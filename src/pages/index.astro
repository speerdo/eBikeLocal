---
export const prerender = false;

import BaseLayout from '@layouts/BaseLayout.astro';
import SearchBar from '@components/ui/SearchBar.astro';
import sql from '@lib/neon';

// Dynamic stats
const [shopCount, brandCount, cityCount] = await Promise.all([
  sql`SELECT COUNT(*) as count FROM shops WHERE google_business_status IS NULL OR google_business_status != 'CLOSED_PERMANENTLY'`,
  sql`SELECT COUNT(*) as count FROM brands WHERE is_active = true`,
  sql`SELECT COUNT(*) as count FROM cities WHERE has_dedicated_page = true`,
]);

// Featured cities (most shops)
const featuredCities = await sql`
  SELECT c.name, c.slug, c.shop_count, s.slug as state_slug, s.code as state_code
  FROM cities c
  JOIN states s ON s.code = c.state_code
  WHERE c.has_dedicated_page = true AND c.shop_count > 0
  ORDER BY c.shop_count DESC
  LIMIT 12
`;

// All brands for the row
const brands = await sql`
  SELECT name, slug, logo_url, price_range_low, price_range_high
  FROM brands WHERE is_active = true
  ORDER BY estimated_us_dealers DESC NULLS LAST
  LIMIT 10
`;

const totalShops = Number(shopCount[0].count);
const totalBrands = Number(brandCount[0].count);
const totalCities = Number(cityCount[0].count);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'eBikeLocal',
  url: 'https://ebikelocal.com',
  description: 'Find eBike shops, brands, and bikes near you.',
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://ebikelocal.com/api/search?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};
---

<BaseLayout
  title="eBikeLocal — Find eBike Shops, Brands & Bikes Near You"
  description={`Find ${totalShops.toLocaleString()} eBike shops across ${totalCities} cities. Compare local dealers, see which brands they carry, and shop the best electric bikes.`}
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-brand-50 to-white py-16 md:py-24">
    <div class="mx-auto max-w-4xl px-(--spacing-page) text-center">
      <h1 class="text-4xl font-extrabold tracking-tight text-surface-900 md:text-5xl lg:text-6xl">
        Find eBike Shops Near You
      </h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-surface-700">
        Discover local electric bike dealers, see which brands they carry, and compare the best eBikes — all in one place.
      </p>
      <div class="mx-auto mt-8 max-w-xl">
        <SearchBar size="lg" />
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="border-y border-surface-200 bg-surface-50">
    <div class="mx-auto grid max-w-7xl grid-cols-3 px-(--spacing-page)">
      <div class="border-r border-surface-200 py-6 text-center">
        <p class="text-3xl font-extrabold text-brand-600">{totalShops.toLocaleString()}+</p>
        <p class="mt-1 text-sm text-surface-700">eBike Shops</p>
      </div>
      <div class="border-r border-surface-200 py-6 text-center">
        <p class="text-3xl font-extrabold text-brand-600">{totalBrands}</p>
        <p class="mt-1 text-sm text-surface-700">Brands Tracked</p>
      </div>
      <div class="py-6 text-center">
        <p class="text-3xl font-extrabold text-brand-600">{totalCities}+</p>
        <p class="mt-1 text-sm text-surface-700">Cities Covered</p>
      </div>
    </div>
  </section>

  <!-- Featured cities -->
  {featuredCities.length > 0 && (
    <section class="mx-auto max-w-7xl px-(--spacing-page) py-16">
      <div class="flex items-center justify-between">
        <h2 class="text-2xl font-bold text-surface-900">Popular Cities</h2>
        <a href="/shops/" class="text-sm font-medium text-brand-600 hover:underline">View all →</a>
      </div>
      <div class="mt-6 grid gap-3 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
        {featuredCities.map((city) => (
          <a
            href={`/shops/${city.state_slug}/${city.slug}/`}
            class="flex items-center justify-between rounded-lg border border-surface-200 px-4 py-3 transition-colors hover:border-brand-600 hover:bg-brand-50"
          >
            <div>
              <p class="font-medium text-surface-900">{city.name}</p>
              <p class="text-xs text-surface-700">{city.state_code}</p>
            </div>
            <span class="text-sm font-medium text-surface-700">{city.shop_count} shops</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Featured brands -->
  {brands.length > 0 && (
    <section class="border-t border-surface-200 bg-surface-50 py-12">
      <div class="mx-auto max-w-7xl px-(--spacing-page)">
        <div class="flex items-center justify-between">
          <h2 class="text-2xl font-bold text-surface-900">Top eBike Brands</h2>
          <a href="/brands/" class="text-sm font-medium text-brand-600 hover:underline">All brands →</a>
        </div>
        <div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-5">
          {brands.map((brand) => (
            <a
              href={`/brands/${brand.slug}/`}
              class="flex flex-col items-center rounded-lg border border-surface-200 bg-white p-4 text-center transition-shadow hover:shadow-md"
            >
              {brand.logo_url ? (
                <img src={brand.logo_url} alt={brand.name} class="h-10 w-20 object-contain" loading="lazy" />
              ) : (
                <div class="flex h-10 w-10 items-center justify-center rounded bg-brand-50 text-sm font-bold text-brand-700">
                  {brand.name[0]}
                </div>
              )}
              <p class="mt-2 text-sm font-medium text-surface-900">{brand.name}</p>
              {brand.price_range_low && (
                <p class="text-xs text-surface-700">from ${brand.price_range_low.toLocaleString()}</p>
              )}
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- How it works -->
  <section class="mx-auto max-w-7xl px-(--spacing-page) py-16">
    <h2 class="text-center text-2xl font-bold text-surface-900">How It Works</h2>
    <div class="mt-10 grid gap-8 sm:grid-cols-3">
      <div class="text-center">
        <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-brand-50 text-brand-600">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
        </div>
        <h3 class="mt-4 font-semibold text-surface-900">Search Your Area</h3>
        <p class="mt-2 text-sm text-surface-700">Enter your city or zip code to find eBike shops nearby.</p>
      </div>
      <div class="text-center">
        <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-brand-50 text-brand-600">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" /></svg>
        </div>
        <h3 class="mt-4 font-semibold text-surface-900">Compare Brands</h3>
        <p class="mt-2 text-sm text-surface-700">See which eBike brands each shop carries — data no one else has.</p>
      </div>
      <div class="text-center">
        <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-brand-50 text-brand-600">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
        </div>
        <h3 class="mt-4 font-semibold text-surface-900">Find Your Ride</h3>
        <p class="mt-2 text-sm text-surface-700">Browse bikes, read guides, and buy with confidence.</p>
      </div>
    </div>
  </section>

  <!-- Latest guides -->
  <section class="border-t border-surface-200 bg-surface-50 py-12">
    <div class="mx-auto max-w-7xl px-(--spacing-page)">
      <div class="flex items-center justify-between">
        <h2 class="text-2xl font-bold text-surface-900">eBike Guides</h2>
        <a href="/guides/" class="text-sm font-medium text-brand-600 hover:underline">All guides →</a>
      </div>
      <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {[
          { title: 'eBike Tax Credit 2026', href: '/guides/ebike-tax-credit-2026/', desc: 'How to claim the federal electric bike tax credit.' },
          { title: 'eBike Laws by State', href: '/guides/ebike-laws-by-state/', desc: 'Class rules, helmet laws, and trail access in all 50 states.' },
          { title: 'eBike Classes Explained', href: '/guides/ebike-classes-explained/', desc: 'Class 1 vs 2 vs 3 — what they mean and where you can ride.' },
        ].map(g => (
          <a href={g.href} class="group rounded-lg border border-surface-200 bg-white p-5 transition-shadow hover:shadow-md">
            <h3 class="font-bold text-surface-900 group-hover:text-brand-600 transition-colors">{g.title}</h3>
            <p class="mt-1 text-sm text-surface-700">{g.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
