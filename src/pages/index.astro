---
import BaseLayout from '@layouts/BaseLayout.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'eBikeLocal',
  url: 'https://ebikelocal.com',
  description: 'Find eBike shops, brands, and bikes near you.',
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://ebikelocal.com/api/search?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};
---

<BaseLayout
  title="eBikeLocal — Find eBike Shops, Brands & Bikes Near You"
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-brand-50 to-white py-16 md:py-24">
    <div class="mx-auto max-w-4xl px-(--spacing-page) text-center">
      <h1 class="text-4xl font-extrabold tracking-tight text-surface-900 md:text-5xl lg:text-6xl">
        Find eBike Shops Near You
      </h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-surface-700">
        Discover local electric bike dealers, see which brands they carry, and compare the best eBikes — all in one place.
      </p>

      <!-- Search bar placeholder -->
      <div class="mx-auto mt-8 max-w-xl">
        <form action="/api/search" method="get" class="flex gap-2">
          <input
            type="text"
            name="q"
            placeholder="Enter your city or zip code..."
            class="flex-1 rounded-lg border border-surface-200 bg-white px-4 py-3 text-sm shadow-sm transition-colors placeholder:text-surface-700/50 focus:border-brand-600 focus:outline-none focus:ring-2 focus:ring-brand-600/20"
          />
          <button
            type="submit"
            class="rounded-lg bg-brand-600 px-6 py-3 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-brand-700"
          >
            Search
          </button>
        </form>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="mx-auto max-w-7xl px-(--spacing-page) py-16">
    <h2 class="text-center text-2xl font-bold text-surface-900">How It Works</h2>
    <div class="mt-10 grid gap-8 sm:grid-cols-3">
      <div class="text-center">
        <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-brand-50 text-brand-600">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
        <h3 class="mt-4 font-semibold text-surface-900">Search Your Area</h3>
        <p class="mt-2 text-sm text-surface-700">Enter your city or zip code to find eBike shops nearby.</p>
      </div>
      <div class="text-center">
        <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-brand-50 text-brand-600">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
          </svg>
        </div>
        <h3 class="mt-4 font-semibold text-surface-900">Compare Brands</h3>
        <p class="mt-2 text-sm text-surface-700">See which eBike brands each shop carries — data no one else has.</p>
      </div>
      <div class="text-center">
        <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-brand-50 text-brand-600">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </div>
        <h3 class="mt-4 font-semibold text-surface-900">Find Your Ride</h3>
        <p class="mt-2 text-sm text-surface-700">Browse bikes, read guides, and buy with confidence.</p>
      </div>
    </div>
  </section>

  <!-- Placeholder sections for dynamic content (populated once DB is connected) -->
  <!-- Featured cities, featured brands, latest guides, stats bar -->
</BaseLayout>
