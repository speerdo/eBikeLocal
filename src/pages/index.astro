---
export const prerender = false;

import BaseLayout from '@layouts/BaseLayout.astro';
import sql from '@lib/neon';

const [shopCount, brandCount, cityCount] = await Promise.all([
  sql`SELECT COUNT(*) as count FROM shops WHERE google_business_status IS NULL OR google_business_status != 'CLOSED_PERMANENTLY'`,
  sql`SELECT COUNT(*) as count FROM brands WHERE is_active = true`,
  sql`SELECT COUNT(*) as count FROM cities WHERE has_dedicated_page = true`,
]);

const featuredCities = await sql`
  SELECT c.name, c.slug, c.shop_count, s.slug as state_slug, s.code as state_code, s.name as state_name
  FROM cities c
  JOIN states s ON s.code = c.state_code
  WHERE c.has_dedicated_page = true AND c.shop_count > 0
  ORDER BY c.shop_count DESC
  LIMIT 12
`;

const brands = await sql`
  SELECT name, slug, logo_url, price_range_low, price_range_high, description
  FROM brands WHERE is_active = true
  ORDER BY estimated_us_dealers DESC NULLS LAST
  LIMIT 8
`;

const totalShops = Number(shopCount[0].count);
const totalBrands = Number(brandCount[0].count);
const totalCities = Number(cityCount[0].count);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'eBikeLocal',
  url: 'https://ebikelocal.com',
  description: 'Find eBike shops, brands, and bikes near you.',
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://ebikelocal.com/api/search?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};
---

<BaseLayout
  title="eBikeLocal — Find eBike Shops, Brands & Bikes Near You"
  description={`Find ${totalShops > 0 ? totalShops.toLocaleString() : 'thousands of'} eBike shops across ${totalCities > 0 ? totalCities : 'hundreds of'} cities. Compare local dealers, see which brands they carry, and discover the best electric bikes.`}
  jsonLd={jsonLd}
>

  <!-- ═══════════════════════════════════════════════════════════
       HERO
  ══════════════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-surface-950">
    <!-- Background image with overlay -->
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1571068316344-75bc76f77890?w=1600&q=80&auto=format&fit=crop"
        alt=""
        class="h-full w-full object-cover opacity-30"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-br from-surface-950 via-surface-950/90 to-brand-900/50"></div>
      <!-- Dot grid overlay -->
      <div class="absolute inset-0 bg-dot-grid opacity-10"></div>
    </div>

    <!-- Glow orbs -->
    <div class="absolute -top-24 -right-24 h-96 w-96 rounded-full bg-brand-600/20 blur-3xl pointer-events-none"></div>
    <div class="absolute -bottom-12 left-1/3 h-64 w-64 rounded-full bg-accent-500/10 blur-3xl pointer-events-none"></div>

    <div class="relative mx-auto max-w-7xl page-x py-24 md:py-32">
      <div class="mx-auto max-w-3xl text-center">
        <!-- Badge -->
        <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-brand-500/30 bg-brand-500/10 px-4 py-1.5 text-sm font-medium text-brand-300">
          <svg class="h-3.5 w-3.5 text-accent-400" viewBox="0 0 16 16" fill="currentColor">
            <path d="M8 0l1.8 5.5H16l-4.6 3.3 1.8 5.5L8 11l-5.2 3.3 1.8-5.5L0 5.5h6.2z"/>
          </svg>
          The only directory with brand-level dealer data
        </div>

        <!-- Headline -->
        <h1 class="font-display text-4xl font-extrabold tracking-tight text-white md:text-5xl lg:text-6xl xl:text-7xl">
          Find the Best
          <span class="relative">
            <span class="text-gradient"> eBike Shop</span>
          </span>
          <br />Near You
        </h1>

        <p class="mx-auto mt-6 max-w-2xl text-lg text-surface-300 md:text-xl">
          We aggregate dealer data from 15+ brands so you can find a local shop, see what they carry, and ride smarter — no more clicking through 20 brand websites.
        </p>

        <!-- Search -->
        <div class="mx-auto mt-10 max-w-xl">
          <form action="/api/search" method="get" class="flex gap-2">
            <div class="relative flex-1">
              <svg class="absolute left-3.5 top-1/2 h-4.5 w-4.5 -translate-y-1/2 text-surface-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
              <input
                type="text"
                name="q"
                placeholder="City, state, or zip code..."
                class="w-full rounded-xl border-0 bg-white/10 pl-11 pr-4 py-3.5 text-sm text-white ring-1 ring-white/20 placeholder:text-surface-400 focus:bg-white/15 focus:ring-brand-400 focus:outline-none transition-all backdrop-blur-sm"
              />
            </div>
            <button
              type="submit"
              class="shrink-0 rounded-xl bg-brand-600 px-6 py-3.5 text-sm font-semibold text-white shadow-lg hover:bg-brand-500 active:scale-95 transition-all"
            >
              Search
            </button>
          </form>

          <p class="mt-3 text-xs text-surface-500">
            Try: "Austin TX" · "Denver" · "98101"
          </p>
        </div>

        <!-- Quick links -->
        <div class="mt-8 flex flex-wrap justify-center gap-2">
          {[
            { label: '🗺️ Browse by State', href: '/shops/' },
            { label: '⚡ View All Brands', href: '/brands/' },
            { label: '🏆 Best eBikes 2026', href: '/best/' },
            { label: '📋 eBike Laws', href: '/guides/ebike-laws-by-state/' },
          ].map(l => (
            <a
              href={l.href}
              class="rounded-full border border-white/10 bg-white/5 px-4 py-1.5 text-xs font-medium text-surface-300 backdrop-blur-sm hover:bg-white/10 hover:text-white transition-colors"
            >
              {l.label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       STATS BAR
  ══════════════════════════════════════════════════════════════ -->
  <section class="border-b border-surface-100 bg-white">
    <div class="mx-auto max-w-7xl page-x">
      <div class="grid grid-cols-3 divide-x divide-surface-100">
        {[
          { value: totalShops > 0 ? `${totalShops.toLocaleString()}+` : 'Thousands', label: 'eBike Shops', icon: '🏪' },
          { value: String(totalBrands || 15), label: 'Brands Tracked', icon: '⚡' },
          { value: totalCities > 0 ? `${totalCities}+` : 'Hundreds of', label: 'Cities', icon: '🗺️' },
        ].map(stat => (
          <div class="flex flex-col items-center py-6 md:flex-row md:justify-center md:gap-4">
            <span class="text-2xl" aria-hidden="true">{stat.icon}</span>
            <div class="mt-1 text-center md:mt-0 md:text-left">
              <p class="font-display text-2xl font-extrabold text-surface-900 md:text-3xl">{stat.value}</p>
              <p class="text-xs font-medium text-surface-500 md:text-sm">{stat.label}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       THE UNIQUE VALUE PROP
  ══════════════════════════════════════════════════════════════ -->
  <section class="section-y bg-surface-50">
    <div class="mx-auto max-w-7xl page-x">
      <div class="mx-auto max-w-2xl text-center">
        <p class="text-xs font-semibold uppercase tracking-widest text-brand-600">Why eBikeLocal</p>
        <h2 class="font-display mt-3 text-3xl font-extrabold text-surface-900 md:text-4xl">
          No other directory tells you what's in stock
        </h2>
        <p class="mt-4 text-surface-600">
          Every brand maintains its own siloed dealer locator. We aggregate all of them — so you can see which brands a shop carries before you drive there.
        </p>
      </div>

      <div class="mt-14 grid gap-6 sm:grid-cols-3">
        {[
          {
            icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>`,
            title: 'Brand-Level Data',
            desc: 'See exactly which eBike brands each shop carries — Aventon, Trek, Specialized, and 12 more. No one else has this.',
          },
          {
            icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
            title: 'City-Level Pages',
            desc: 'Every city gets its own page with a map, shop list, local law summary, and brands available — fully indexed for search.',
          },
          {
            icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
            title: 'Verified & Enriched',
            desc: 'Every listing is cross-referenced with Google Places, brand locators, and review data — not scraped duplicates.',
          },
        ].map(feature => (
          <div class="rounded-2xl border border-surface-200 bg-white p-7 shadow-card">
            <div class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-brand-50 text-brand-600" set:html={feature.icon} />
            <h3 class="mt-4 font-display text-lg font-bold text-surface-900">{feature.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-surface-600">{feature.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       FEATURED CITIES
  ══════════════════════════════════════════════════════════════ -->
  {featuredCities.length > 0 && (
    <section class="section-y bg-white">
      <div class="mx-auto max-w-7xl page-x">
        <div class="flex items-end justify-between">
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-brand-600">Shop Directory</p>
            <h2 class="font-display mt-2 text-3xl font-extrabold text-surface-900">Popular Cities</h2>
          </div>
          <a href="/shops/" class="hidden text-sm font-medium text-brand-600 hover:text-brand-700 sm:inline-flex items-center gap-1">
            Browse all states →
          </a>
        </div>

        <div class="mt-8 grid gap-3 grid-cols-2 sm:grid-cols-3 md:grid-cols-4">
          {featuredCities.map((city) => (
            <a
              href={`/shops/${city.state_slug}/${city.slug}/`}
              class="group card-hover flex items-center justify-between rounded-xl border border-surface-200 bg-white px-4 py-3.5 shadow-card"
            >
              <div class="min-w-0">
                <p class="truncate font-semibold text-surface-900 group-hover:text-brand-600 transition-colors">{city.name}</p>
                <p class="text-xs text-surface-500">{city.state_name}</p>
              </div>
              <span class="ml-2 shrink-0 rounded-full bg-brand-50 px-2 py-0.5 text-xs font-semibold text-brand-700">
                {city.shop_count}
              </span>
            </a>
          ))}
        </div>

        <div class="mt-6 text-center sm:hidden">
          <a href="/shops/" class="text-sm font-medium text-brand-600">Browse all states →</a>
        </div>
      </div>
    </section>
  )}

  <!-- ═══════════════════════════════════════════════════════════
       BRANDS ROW
  ══════════════════════════════════════════════════════════════ -->
  {brands.length > 0 && (
    <section class="section-y bg-surface-50 border-y border-surface-100">
      <div class="mx-auto max-w-7xl page-x">
        <div class="flex items-end justify-between">
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-brand-600">Electric Bikes</p>
            <h2 class="font-display mt-2 text-3xl font-extrabold text-surface-900">Top eBike Brands</h2>
          </div>
          <a href="/brands/" class="hidden text-sm font-medium text-brand-600 hover:text-brand-700 sm:inline-flex items-center gap-1">
            All brands →
          </a>
        </div>

        <div class="mt-8 grid grid-cols-2 gap-4 sm:grid-cols-4">
          {brands.map((brand) => (
            <a
              href={`/brands/${brand.slug}/`}
              class="group card-hover flex flex-col rounded-2xl border border-surface-200 bg-white p-5 shadow-card"
            >
              <!-- Logo placeholder -->
              <div class="flex h-14 items-center">
                {brand.logo_url ? (
                  <img
                    src={brand.logo_url}
                    alt={brand.name}
                    class="max-h-10 max-w-full object-contain"
                    loading="lazy"
                  />
                ) : (
                  <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-600 text-lg font-extrabold text-white font-display">
                    {brand.name[0]}
                  </div>
                )}
              </div>
              <h3 class="mt-3 font-display text-base font-bold text-surface-900 group-hover:text-brand-600 transition-colors">{brand.name}</h3>
              {brand.price_range_low && (
                <p class="mt-0.5 text-xs text-surface-500">
                  From ${brand.price_range_low.toLocaleString()}
                </p>
              )}
              <p class="mt-2 text-xs leading-relaxed text-surface-600 line-clamp-2">{brand.description}</p>
            </a>
          ))}
        </div>

        <div class="mt-6 text-center sm:hidden">
          <a href="/brands/" class="text-sm font-medium text-brand-600">View all brands →</a>
        </div>
      </div>
    </section>
  )}

  <!-- ═══════════════════════════════════════════════════════════
       SOCIAL PROOF / HOW IT WORKS
  ══════════════════════════════════════════════════════════════ -->
  <section class="section-y bg-white">
    <div class="mx-auto max-w-7xl page-x">
      <div class="mx-auto max-w-2xl text-center">
        <p class="text-xs font-semibold uppercase tracking-widest text-brand-600">Simple Process</p>
        <h2 class="font-display mt-3 text-3xl font-extrabold text-surface-900 md:text-4xl">
          Find your local dealer in 3 steps
        </h2>
      </div>

      <div class="mt-14 grid gap-8 sm:grid-cols-3">
        {[
          { step: '01', title: 'Search your area', desc: 'Enter your city or zip code to instantly see all eBike shops nearby on an interactive map.', icon: '🔍' },
          { step: '02', title: 'Filter by brand', desc: 'See which brands each shop stocks — Aventon, Trek, Specialized, Giant, and many more.', icon: '⚡' },
          { step: '03', title: 'Visit or buy online', desc: 'Get directions, hours, and phone number — or click through to buy directly from the brand.', icon: '🚲' },
        ].map((item, i) => (
          <div class="relative">
            {i < 2 && (
              <div class="absolute top-6 left-full z-10 hidden h-px w-full bg-gradient-to-r from-surface-200 to-transparent sm:block" style="width: calc(50% + 2rem); left: calc(50% + 2rem)"></div>
            )}
            <div class="flex flex-col items-center text-center">
              <div class="relative flex h-14 w-14 items-center justify-center rounded-2xl bg-brand-50 text-2xl shadow-sm ring-4 ring-white">
                {item.icon}
                <span class="absolute -top-2 -right-2 flex h-5 w-5 items-center justify-center rounded-full bg-brand-600 text-[10px] font-bold text-white">
                  {i + 1}
                </span>
              </div>
              <h3 class="mt-5 font-display text-lg font-bold text-surface-900">{item.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-surface-600">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       GUIDES / CONTENT
  ══════════════════════════════════════════════════════════════ -->
  <section class="section-y bg-surface-950">
    <div class="mx-auto max-w-7xl page-x">
      <div class="flex items-end justify-between">
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-brand-400">Expert Content</p>
          <h2 class="font-display mt-2 text-3xl font-extrabold text-white">eBike Guides & Resources</h2>
        </div>
        <a href="/guides/" class="hidden text-sm font-medium text-brand-400 hover:text-brand-300 sm:inline-flex items-center gap-1">
          All guides →
        </a>
      </div>

      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {[
          {
            tag: 'Tax & Finance',
            title: 'eBike Tax Credit 2026',
            desc: 'How to claim the federal electric bicycle tax credit and maximize your savings.',
            href: '/guides/ebike-tax-credit-2026/',
            emoji: '💰',
          },
          {
            tag: 'Laws & Regulations',
            title: 'eBike Laws by State',
            desc: 'Class rules, helmet requirements, trail access, and rebate programs in all 50 states.',
            href: '/guides/ebike-laws-by-state/',
            emoji: '⚖️',
          },
          {
            tag: 'Buying Advice',
            title: 'How to Choose an eBike',
            desc: 'A step-by-step guide to finding the right electric bike for your riding style and budget.',
            href: '/guides/how-to-choose-an-ebike/',
            emoji: '🎯',
          },
        ].map(guide => (
          <a
            href={guide.href}
            class="group card-hover flex flex-col rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur-sm hover:border-brand-500/30 hover:bg-white/10"
          >
            <div class="flex items-center gap-3">
              <span class="text-3xl">{guide.emoji}</span>
              <span class="rounded-full bg-brand-500/20 px-2.5 py-0.5 text-xs font-medium text-brand-300">{guide.tag}</span>
            </div>
            <h3 class="mt-4 font-display text-lg font-bold text-white group-hover:text-brand-300 transition-colors">{guide.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-surface-400">{guide.desc}</p>
            <div class="mt-4 flex items-center gap-1 text-xs font-medium text-brand-400 group-hover:text-brand-300">
              Read guide <svg class="h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       BOTTOM CTA
  ══════════════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-brand-600 py-16">
    <div class="absolute inset-0 bg-dot-grid opacity-10"></div>
    <div class="absolute -top-20 -right-20 h-72 w-72 rounded-full bg-brand-500/30 blur-3xl pointer-events-none"></div>
    <div class="relative mx-auto max-w-3xl page-x text-center">
      <h2 class="font-display text-3xl font-extrabold text-white md:text-4xl">
        Ready to find your local eBike dealer?
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-brand-200">
        Search our directory of {totalShops > 0 ? `${totalShops.toLocaleString()}+` : 'thousands of'} shops across the US. Free, no account required.
      </p>
      <div class="mt-8 flex flex-col items-center gap-3 sm:flex-row sm:justify-center">
        <a
          href="/shops/"
          class="rounded-xl bg-white px-8 py-3.5 text-sm font-bold text-brand-700 shadow-lg hover:bg-brand-50 transition-colors"
        >
          Browse the Directory
        </a>
        <a
          href="/brands/"
          class="rounded-xl border border-brand-400 px-8 py-3.5 text-sm font-semibold text-white hover:bg-brand-500 transition-colors"
        >
          Compare Brands
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
