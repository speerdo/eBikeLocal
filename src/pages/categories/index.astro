---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/ui/Breadcrumb.astro';
import PageHeader from '@components/ui/PageHeader.astro';
import sql from '@lib/neon';

const categories = await sql`
  SELECT c.*, COUNT(bc.bike_id) as bike_count
  FROM categories c
  LEFT JOIN bike_categories bc ON bc.category_id = c.id
  GROUP BY c.id
  ORDER BY c.sort_order, c.name
`;
---

<BaseLayout
  title="eBike Categories — Browse Electric Bikes by Riding Style"
  description="Browse electric bikes by category: commuter, cargo, mountain, folding, fat tire, moped-style and more. Find the right eBike for your riding style."
>
  <PageHeader
    eyebrow="Categories"
    title="Browse by Riding Style"
    subtitle="From daily commuters to off-road hunters — find the right type of eBike for you."
  />

  <div class="mx-auto max-w-7xl page-x py-8">
    <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Categories' }]} />

    <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      {categories.map((cat) => (
        <a
          href={`/categories/${cat.slug}/`}
          class="group card-hover flex flex-col rounded-2xl border border-surface-200 bg-white p-6 shadow-card"
        >
          <span class="text-4xl" aria-hidden="true">{cat.icon}</span>
          <h2 class="mt-3 font-display text-lg font-bold text-surface-900 group-hover:text-brand-600 transition-colors">
            {cat.name}
          </h2>
          {cat.description && (
            <p class="mt-2 text-sm leading-relaxed text-surface-600 line-clamp-3">{cat.description}</p>
          )}
          {Number(cat.bike_count) > 0 && (
            <p class="mt-3 text-xs font-medium text-surface-400">
              {cat.bike_count} bikes
            </p>
          )}
          <div class="mt-auto pt-4">
            <span class="inline-flex items-center gap-1 text-sm font-semibold text-brand-600 group-hover:gap-2 transition-all">
              Browse {cat.name}
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
