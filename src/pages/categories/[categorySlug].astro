---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/ui/Breadcrumb.astro';
import BikeCard from '@components/ui/BikeCard.astro';
import sql from '@lib/neon';

export async function getStaticPaths() {
  const categories = await sql`SELECT slug FROM categories`;
  return categories.map((c) => ({ params: { categorySlug: c.slug } }));
}

const { categorySlug } = Astro.params;
const [category] = await sql`SELECT * FROM categories WHERE slug = ${categorySlug} LIMIT 1`;
if (!category) return Astro.redirect('/404');

const bikes = await sql`
  SELECT bk.*, br.name as brand_name, br.slug as brand_slug, br.logo_url as brand_logo_url, br.website as brand_website
  FROM bikes bk
  JOIN brands br ON br.id = bk.brand_id
  JOIN bike_categories bc ON bc.bike_id = bk.id
  WHERE bc.category_id = ${category.id} AND bk.is_active = true
  ORDER BY bk.msrp ASC NULLS LAST, bk.model_name ASC
`;

const topPicks = bikes.filter((b) => b.best_for).slice(0, 3);
---

<BaseLayout
  title={`Popular ${category.name} eBikes — Compare Models We Track`}
  description={`Popular ${category.name.toLowerCase()} electric bikes in our catalog (not exhaustive). ${category.description || ''}`}
>
  <div class="mx-auto max-w-7xl page-x py-8">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: 'Categories', href: '/categories/' },
      { label: category.name },
    ]} />

    <h1 class="mt-6 text-3xl font-extrabold text-surface-900 md:text-4xl">Popular {category.name} eBikes</h1>
    {category.description && <p class="mt-2 text-lg text-surface-700">{category.description}</p>}

    {topPicks.length > 0 && (
      <section class="mt-10">
        <h2 class="text-xl font-bold text-surface-900">Popular picks</h2>
        <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {topPicks.map((bike) => (
            <BikeCard
              modelName={bike.model_name}
              brandName={bike.brand_name}
              brandSlug={bike.brand_slug}
              brandLogoUrl={bike.brand_logo_url}
              brandWebsite={bike.brand_website}
              slug={bike.slug}
              msrp={bike.msrp}
              salePrice={bike.sale_price}
              heroImageUrl={bike.hero_image_url}
              galleryImages={bike.gallery_images}
              motorWatts={bike.motor_watts}
              batteryWh={bike.battery_wh}
              rangeMilesHigh={bike.range_miles_high}
              bestFor={bike.best_for}
              affiliateUrl={bike.affiliate_url}
            />
          ))}
        </div>
      </section>
    )}

    <!-- Comparison table -->
    {bikes.length > 1 && (
      <section class="mt-12">
        <h2 class="text-xl font-bold text-surface-900 mb-4">Compare {category.name} eBikes</h2>
        <div class="overflow-x-auto rounded-xl border border-surface-200 shadow-sm">
          <table class="min-w-full text-sm">
            <thead>
              <tr class="border-b border-surface-200 bg-surface-50">
                <th class="sticky left-0 z-10 bg-surface-50 px-4 py-3 text-left font-700 text-surface-700 whitespace-nowrap">Bike</th>
                <th class="px-4 py-3 text-right font-700 text-surface-700 whitespace-nowrap">Price</th>
                <th class="px-4 py-3 text-right font-700 text-surface-700 whitespace-nowrap">Motor</th>
                <th class="px-4 py-3 text-right font-700 text-surface-700 whitespace-nowrap">Battery</th>
                <th class="px-4 py-3 text-right font-700 text-surface-700 whitespace-nowrap">Range</th>
                <th class="px-4 py-3 text-right font-700 text-surface-700 whitespace-nowrap">Class</th>
                <th class="px-4 py-3 text-left font-700 text-surface-700 whitespace-nowrap">Best For</th>
              </tr>
            </thead>
            <tbody>
              {bikes.map((bike, i) => (
                <tr class={`border-b border-surface-100 transition-colors hover:bg-brand-50/50 ${i % 2 === 0 ? 'bg-white' : 'bg-surface-50/50'}`}>
                  <td class={`sticky left-0 z-10 px-4 py-3 whitespace-nowrap ${i % 2 === 0 ? 'bg-white' : 'bg-surface-50'}`}>
                    <a href={`/bikes/${bike.brand_slug}/${bike.slug}/`} class="font-600 text-surface-900 hover:text-brand-600 transition-colors">
                      {bike.brand_name} {bike.model_name}
                    </a>
                  </td>
                  <td class="px-4 py-3 text-right text-surface-700 whitespace-nowrap">
                    {bike.sale_price
                      ? <><span class="font-600 text-surface-900">${bike.sale_price.toLocaleString()}</span></>
                      : bike.msrp
                        ? `$${bike.msrp.toLocaleString()}`
                        : '—'}
                  </td>
                  <td class="px-4 py-3 text-right text-surface-700 whitespace-nowrap">
                    {bike.motor_watts ? `${bike.motor_watts}W` : '—'}
                  </td>
                  <td class="px-4 py-3 text-right text-surface-700 whitespace-nowrap">
                    {bike.battery_wh ? `${bike.battery_wh}Wh` : '—'}
                  </td>
                  <td class="px-4 py-3 text-right text-surface-700 whitespace-nowrap">
                    {bike.range_miles_high ? `${bike.range_miles_high} mi` : '—'}
                  </td>
                  <td class="px-4 py-3 text-right whitespace-nowrap">
                    {bike.class_type
                      ? <span class="rounded-full bg-surface-100 px-2 py-0.5 text-xs font-600 text-surface-600">{bike.class_type}</span>
                      : <span class="text-surface-400">—</span>}
                  </td>
                  <td class="px-4 py-3 text-surface-600 max-w-[180px]">
                    {bike.best_for || '—'}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    )}

    <section class="mt-12">
      <h2 class="text-xl font-bold text-surface-900">Popular {category.name} eBikes</h2>
      <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        {bikes.map((bike) => (
          <BikeCard
            modelName={bike.model_name}
            brandName={bike.brand_name}
            brandSlug={bike.brand_slug}
            brandLogoUrl={bike.brand_logo_url}
            brandWebsite={bike.brand_website}
            slug={bike.slug}
            msrp={bike.msrp}
            salePrice={bike.sale_price}
            heroImageUrl={bike.hero_image_url}
            galleryImages={bike.gallery_images}
            motorWatts={bike.motor_watts}
            batteryWh={bike.battery_wh}
            rangeMilesHigh={bike.range_miles_high}
            bestFor={bike.best_for}
            affiliateUrl={bike.affiliate_url}
          />
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
