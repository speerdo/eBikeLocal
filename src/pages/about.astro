---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/ui/Breadcrumb.astro';
import { getSiteStats } from '@lib/siteStats';

const { shopCount, brandCount, cityPageCount } = await getSiteStats();
const aboutDesc = `Learn how eBikeLocal aggregates dealer and brand data from ${brandCount.toLocaleString()} tracked brands and ${shopCount.toLocaleString()} US shop listings, how our editorial process works, and how we verify listings.`;
---

<BaseLayout
  title="About eBikeLocal — Why We Built This Directory"
  description={aboutDesc}
>
  <div class="mx-auto max-w-4xl page-x py-8">
    <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'About' }]} />

    <h1 class="mt-6 text-3xl font-extrabold text-surface-900 md:text-4xl">About eBikeLocal</h1>

    <div class="mt-6 space-y-6 text-surface-700 leading-relaxed">
      <section>
        <h2 class="text-xl font-bold text-surface-900">Why this exists</h2>
        <p class="mt-2">
          eBikeLocal started from a simple frustration: if you wanted to buy an eBike and test-ride it locally, you had to open a dozen brand websites — each with its own dealer locator, each showing only its own brands, with no way to compare which shops near you carried multiple brands.
        </p>
        <p class="mt-2">
          We spent over a year aggregating dealer data from {brandCount.toLocaleString()} tracked brands via locator APIs and cross-referencing those records with Google Places data, address normalization, and geographic deduplication. The result is the only directory that answers the question: <strong>"Which shops near me carry Aventon, Trek, and Specialized — all in one place?"</strong>
        </p>
      </section>

      <section>
        <h2 class="text-xl font-bold text-surface-900">What makes our data different</h2>
        <p class="mt-2">
          Every other shop directory either lists general bike shops without brand specifics, or comes directly from a single brand's locator. eBikeLocal is built on a <strong>brand-level junction dataset</strong> — for each shop in our database, we track which brands that shop is an authorized dealer for.
        </p>
        <p class="mt-2">
          Our data pipeline pulls directly from brand dealer APIs (including Beeline Connect, Trek OCC, Specialized's Yext GraphQL endpoint, Giant's bounding-box locator, and others), normalizes addresses, deduplicates records across sources, and enriches each listing with Google Places ratings, hours, and photos. Today the database covers <strong>{shopCount.toLocaleString()} active eBike shop listings</strong> with <strong>{cityPageCount.toLocaleString()} cities that have dedicated directory pages</strong>.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-bold text-surface-900">Editorial and buying guide standards</h2>
        <p class="mt-2">
          Our buying guides and best-picks lists are written based on spec review, category fit, component safety, and price-to-value analysis — not manufacturer relationships or affiliate revenue. When a brand undergoes a material change (like Rad Power Bikes' Chapter 11 filing in late 2025), we update the content and surface warnings to readers rather than quietly removing recommendations.
        </p>
        <p class="mt-2">
          Guide content is reviewed periodically and each guide displays a "last updated" date. For time-sensitive topics like tax credits and state rebate programs, we treat anything older than three months as overdue for review.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-bold text-surface-900">Claiming or updating your shop listing</h2>
        <p class="mt-2">
          If you own or manage an eBike shop that appears in our directory, you can request a listing update, add your hours, or claim the listing to control the description. Use the <a href="/contact/" class="font-medium text-brand-600 hover:underline">Contact page</a> to reach us — include your shop name, city, and the correction or update you'd like made.
        </p>
        <p class="mt-2">
          Verified Partner listings are also available for shops that want enhanced placement and direct traffic from city pages. <a href="/contact/" class="font-medium text-brand-600 hover:underline">Contact us</a> for details.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-bold text-surface-900">Affiliate disclosure</h2>
        <p class="mt-2">
          Some outbound product links on brand and bike pages are affiliate links — clicking them and making a purchase may earn us a commission at no cost to you. This doesn't influence our editorial recommendations or shop listings. Read our full policy on the <a href="/disclosure/" class="font-medium text-brand-600 hover:underline">Affiliate Disclosure</a> page.
        </p>
      </section>
    </div>
  </div>
</BaseLayout>
