---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/ui/Breadcrumb.astro';
import BikeCard from '@components/ui/BikeCard.astro';
import sql from '@lib/neon';

const bikes = await sql`
  SELECT bk.*, br.name as brand_name, br.slug as brand_slug, br.logo_url as brand_logo_url, br.website as brand_website
  FROM bikes bk
  JOIN brands br ON br.id = bk.brand_id
  WHERE bk.is_active = true
  ORDER BY bk.msrp ASC NULLS LAST, bk.model_name ASC
`;

const categories = await sql`SELECT * FROM categories ORDER BY sort_order, name`;
---

<BaseLayout
  title="eBike Catalog — Compare Electric Bikes by Brand, Price & Category"
  description="Browse popular electric bikes from top brands in our catalog (not exhaustive). Filter by category, price, and specs."
>
  <div class="mx-auto max-w-7xl px-(--spacing-page) py-8">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: 'Bikes' },
    ]} />

    <h1 class="mt-6 text-3xl font-extrabold text-surface-900 md:text-4xl">eBike Catalog</h1>
    <p class="mt-2 text-lg text-surface-700">Compare {bikes.length} popular models from top brands — a sample catalog, not every bike sold.</p>

    <section class="mt-6 max-w-3xl rounded-xl border border-surface-200 bg-surface-50 p-5 text-sm leading-relaxed text-surface-700">
      <p>
        This catalog is designed for side-by-side comparison, not a full OEM inventory dump.
        We prioritize mainstream models with enough public specs to evaluate value, expected use case, and practical ownership factors like service support and parts availability.
      </p>
      <p class="mt-3">
        Start with category filters, then compare motor output, battery size, estimated range, and pricing.
        When you find a candidate, open the model page for deeper specs and use dealer pages to confirm local availability before you buy.
      </p>
    </section>

    <!-- Category filter chips -->
    {categories.length > 0 && (
      <div class="mt-6 flex flex-wrap gap-2">
        {categories.map((cat) => (
          <a
            href={`/categories/${cat.slug}/`}
            class="rounded-full border border-surface-200 px-3 py-1.5 text-sm font-medium transition-colors hover:border-brand-600 hover:text-brand-600"
          >
            {cat.name}
          </a>
        ))}
      </div>
    )}

    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      {bikes.map((bike) => (
        <BikeCard
          modelName={bike.model_name}
          brandName={bike.brand_name}
          brandSlug={bike.brand_slug}
          brandLogoUrl={bike.brand_logo_url}
          brandWebsite={bike.brand_website}
          slug={bike.slug}
          msrp={bike.msrp}
          salePrice={bike.sale_price}
          heroImageUrl={bike.hero_image_url}
          galleryImages={bike.gallery_images}
          affiliateUrl={bike.affiliate_url}
          motorWatts={bike.motor_watts}
          batteryWh={bike.battery_wh}
          rangeMilesHigh={bike.range_miles_high}
          bestFor={bike.best_for}
        />
      ))}
    </div>
  </div>
</BaseLayout>
