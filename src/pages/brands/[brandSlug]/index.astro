---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/ui/Breadcrumb.astro';
import BikeCard from '@components/ui/BikeCard.astro';
import CTAButton from '@components/ui/CTAButton.astro';
import AffiliateDisclosureBar from '@components/ui/AffiliateDisclosureBar.astro';
import sql from '@lib/neon';

export async function getStaticPaths() {
  const brands = await sql`SELECT slug FROM brands WHERE is_active = true`;
  return brands.map((b) => ({ params: { brandSlug: b.slug } }));
}

const { brandSlug } = Astro.params;

const [brand] = await sql`SELECT * FROM brands WHERE slug = ${brandSlug} LIMIT 1`;
if (!brand) return Astro.redirect('/404');

const bikes = await sql`
  SELECT * FROM bikes
  WHERE brand_id = ${brand.id} AND is_active = true
  ORDER BY msrp ASC NULLS LAST, model_name ASC
`;

const dealerCount = await sql`
  SELECT COUNT(*) as count
  FROM shop_brands sb
  JOIN shops s ON s.id = sb.shop_id
  WHERE sb.brand_id = ${brand.id}
    AND COALESCE(s.listing_status, 'active') = 'active'
`;

const topPicks = bikes.filter((b) => b.best_for).slice(0, 3);
const featuredBikeSlugs = new Set(topPicks.map((b) => b.slug));
const catalogBikes = bikes.filter((b) => !featuredBikeSlugs.has(b.slug));

const categories = [...new Set(bikes.map((b) => b.category))];

const dealerCities = await sql`
  SELECT DISTINCT c.name, c.slug, st.slug as state_slug, c.state_code
  FROM shop_brands sb
  JOIN shops s ON s.id = sb.shop_id
  JOIN cities c ON c.name = s.city AND c.state_code = s.state_code
  JOIN states st ON st.code = s.state_code
  WHERE sb.brand_id = ${brand.id}
    AND COALESCE(s.listing_status, 'active') = 'active'
  ORDER BY c.name
  LIMIT 20
`;

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `${brand.name} eBike models`,
  itemListElement: bikes.slice(0, 50).map((bike, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    url: `${import.meta.env.SITE_URL || 'https://ebikelocal.com'}/bikes/${brand.slug}/${bike.slug}/`,
    name: `${brand.name} ${bike.model_name}`,
  })),
};
---

<BaseLayout
  title={`Popular ${brand.name} eBikes — Models, Prices & Local Dealers`}
  description={`Popular ${brand.name} electric bikes we track (not an exhaustive catalog). Compare models, prices from $${brand.price_range_low?.toLocaleString() || '?'} to $${brand.price_range_high?.toLocaleString() || '?'}, and find ${brand.name} dealers near you.`}
  jsonLd={itemListSchema}
>
  <div class="mx-auto max-w-7xl px-(--spacing-page) py-8">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: 'Brands', href: '/brands/' },
      { label: brand.name },
    ]} />

    <!-- Brand header -->
    <div class="mt-6 flex items-start gap-4">
      {brand.logo_url && (
        <img src={brand.logo_url} alt={brand.name} class="h-16 w-16 object-contain" />
      )}
      <div>
        <h1 class="text-3xl font-extrabold text-surface-900">{brand.name}</h1>
        {brand.description && <p class="mt-2 text-surface-700">{brand.description}</p>}
      </div>
    </div>

    {brand.slug === 'rad-power-bikes' && (
      <div class="mt-5 rounded-lg border border-amber-200 bg-amber-50 p-4 text-amber-900">
        <p class="text-sm font-semibold">Brand status notice</p>
        <p class="mt-1 text-sm">
          Dealer status may have changed — Rad Power Bikes filed Chapter 11 in Dec 2025.
          Confirm current inventory and dealer authorization directly with the shop before visiting.
        </p>
      </div>
    )}

    <!-- Quick stats -->
    <div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-4">
      <div class="rounded-lg bg-surface-50 p-3 text-center">
        <p class="text-2xl font-bold text-surface-900">{bikes.length}</p>
        <p class="text-xs text-surface-700">Models in our catalog</p>
      </div>
      <div class="rounded-lg bg-surface-50 p-3 text-center">
        <p class="text-2xl font-bold text-surface-900">
          {brand.price_range_low && brand.price_range_high
            ? `$${brand.price_range_low.toLocaleString()}–$${brand.price_range_high.toLocaleString()}`
            : '—'}
        </p>
        <p class="text-xs text-surface-700">Price Range</p>
      </div>
      <div class="rounded-lg bg-surface-50 p-3 text-center">
        <p class="text-2xl font-bold text-surface-900">{Number(dealerCount[0].count).toLocaleString()}</p>
        <p class="text-xs text-surface-700">US Dealers</p>
      </div>
      <div class="rounded-lg bg-surface-50 p-3 text-center">
        <p class="text-2xl font-bold text-surface-900">{categories.length}</p>
        <p class="text-xs text-surface-700">Categories</p>
      </div>
    </div>

    <AffiliateDisclosureBar className="mt-5" />

    <!-- Top picks -->
    {topPicks.length > 0 && (
      <section class="mt-10">
        <h2 class="text-xl font-bold text-surface-900">Popular {brand.name} eBikes</h2>
        <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {topPicks.map((bike) => (
            <BikeCard
              modelName={bike.model_name}
              brandName={brand.name}
              brandSlug={brand.slug}
              brandLogoUrl={brand.logo_url}
              brandWebsite={brand.website}
              slug={bike.slug}
              msrp={bike.msrp}
              salePrice={bike.sale_price}
              heroImageUrl={bike.hero_image_url}
              galleryImages={bike.gallery_images}
              motorWatts={bike.motor_watts}
              batteryWh={bike.battery_wh}
              rangeMilesHigh={bike.range_miles_high}
              bestFor={bike.best_for}
              affiliateUrl={bike.affiliate_url}
            />
          ))}
        </div>
      </section>
    )}

    <!-- Full grid for this brand (sample — not an exhaustive OEM catalog) -->
    <section class="mt-12">
      <h2 class="text-xl font-bold text-surface-900">{brand.name} models in our catalog</h2>
      <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        {catalogBikes.map((bike) => (
          <BikeCard
            modelName={bike.model_name}
            brandName={brand.name}
            brandSlug={brand.slug}
            brandLogoUrl={brand.logo_url}
            brandWebsite={brand.website}
            slug={bike.slug}
            msrp={bike.msrp}
            salePrice={bike.sale_price}
            heroImageUrl={bike.hero_image_url}
            galleryImages={bike.gallery_images}
            motorWatts={bike.motor_watts}
            batteryWh={bike.battery_wh}
            rangeMilesHigh={bike.range_miles_high}
            bestFor={bike.best_for}
            affiliateUrl={bike.affiliate_url}
          />
        ))}
      </div>
    </section>

    <!-- Affiliate CTA -->
    {brand.affiliate_program_url && (
      <div class="mt-8 text-center">
        <CTAButton href={brand.affiliate_program_url} brandName={brand.name} />
      </div>
    )}

    <!-- Find dealers -->
    {dealerCities.length > 0 && (
      <section class="mt-12">
        <h2 class="text-xl font-bold text-surface-900">Find {brand.name} Dealers</h2>
        <div class="mt-4 flex flex-wrap gap-2">
          {dealerCities.map((city) => (
            <a
              href={`/shops/${city.state_slug}/${city.slug}/`}
              class="rounded-full border border-surface-200 px-3 py-1 text-sm transition-colors hover:border-brand-600 hover:text-brand-600"
            >
              {city.name}, {city.state_code}
            </a>
          ))}
        </div>
        <a href={`/brands/${brand.slug}/dealers/`} class="mt-4 inline-block text-sm font-medium text-brand-600 hover:underline">
          View all {brand.name} dealers →
        </a>
      </section>
    )}

    <!-- Brand info -->
    <section class="mt-12 rounded-lg border border-surface-200 p-6">
      <h2 class="text-lg font-bold text-surface-900">About {brand.name}</h2>
      <dl class="mt-3 grid gap-3 text-sm sm:grid-cols-2">
        {brand.founded_year && (
          <div><dt class="text-surface-700">Founded</dt><dd class="font-medium">{brand.founded_year}</dd></div>
        )}
        {brand.headquarters && (
          <div><dt class="text-surface-700">Headquarters</dt><dd class="font-medium">{brand.headquarters}</dd></div>
        )}
        {brand.country_of_origin && (
          <div><dt class="text-surface-700">Country of Origin</dt><dd class="font-medium">{brand.country_of_origin}</dd></div>
        )}
        {brand.website && (
          <div><dt class="text-surface-700">Website</dt><dd><a href={brand.website} target="_blank" rel="noopener" class="font-medium text-brand-600 hover:underline">{brand.website}</a></dd></div>
        )}
      </dl>
    </section>
  </div>
</BaseLayout>
