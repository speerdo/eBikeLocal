---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/ui/Breadcrumb.astro';
import sql from '@lib/neon';

const brands = await sql`
  SELECT b.*, COUNT(sb.shop_id) as dealer_count
  FROM brands b
  LEFT JOIN shop_brands sb ON sb.brand_id = b.id
  WHERE b.is_active = true
  GROUP BY b.id
  ORDER BY dealer_count DESC, b.name
`;
---

<BaseLayout
  title="eBike Brands — Compare Electric Bike Manufacturers"
  description="Browse all eBike brands. Compare prices, find local dealers, and shop the best electric bikes from top manufacturers."
>
  <div class="mx-auto max-w-7xl px-(--spacing-page) py-8">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: 'Brands' },
    ]} />

    <h1 class="mt-6 text-3xl font-extrabold text-surface-900 md:text-4xl">eBike Brands</h1>
    <p class="mt-2 text-lg text-surface-700">Compare top electric bike manufacturers and find local dealers.</p>

    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {brands.map((brand) => (
        <a
          href={`/brands/${brand.slug}/`}
          class="group rounded-lg border border-surface-200 p-5 transition-shadow hover:shadow-md"
        >
          <div class="flex items-center gap-3">
            {brand.logo_url ? (
              <img src={brand.logo_url} alt={brand.name} class="h-10 w-10 object-contain" loading="lazy" />
            ) : (
              <div class="flex h-10 w-10 items-center justify-center rounded bg-surface-100 text-sm font-bold text-surface-700">
                {brand.name[0]}
              </div>
            )}
            <div>
              <h2 class="font-semibold text-surface-900 group-hover:text-brand-600 transition-colors">{brand.name}</h2>
              <p class="text-sm text-surface-700">
                {brand.price_range_low && brand.price_range_high
                  ? `$${brand.price_range_low.toLocaleString()} – $${brand.price_range_high.toLocaleString()}`
                  : ''}
              </p>
            </div>
          </div>
          <p class="mt-3 text-sm text-surface-700 line-clamp-2">{brand.description}</p>
          <div class="mt-3 flex gap-4 text-xs text-surface-700">
            {brand.dealer_count > 0 && <span>{brand.dealer_count} dealers</span>}
            {brand.estimated_us_dealers && <span>~{brand.estimated_us_dealers} US locations</span>}
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
