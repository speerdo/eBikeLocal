---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/ui/Breadcrumb.astro';
import PageHeader from '@components/ui/PageHeader.astro';
import { getBrandLogoUrl } from '@lib/brandLogos';
import sql from '@lib/neon';

const brands = await sql`
  SELECT b.*, COUNT(sb.shop_id) as dealer_count
  FROM brands b
  LEFT JOIN shop_brands sb ON sb.brand_id = b.id
  WHERE b.is_active = true
  GROUP BY b.id
  ORDER BY dealer_count DESC, b.name
`;
---

<BaseLayout
  title="eBike Brands — Compare All Electric Bike Manufacturers"
  description="Compare all major eBike brands — Trek, Specialized, Aventon, Giant, and more. See price ranges, dealer counts, and find a local shop that carries the brand you want."
>
  <PageHeader
    eyebrow="Brands"
    title="Compare eBike Brands"
    subtitle="From budget-friendly DTC brands to premium dealers — find the right brand and a local shop that carries it."
    imageUrl="https://images.unsplash.com/photo-1571068316344-75bc76f77890?w=1200&q=70&auto=format&fit=crop"
    imageAlt="Several electric bicycles lined up for display in a retail showroom"
  />

  <div class="mx-auto max-w-7xl page-x py-8">
    <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Brands' }]} />

    <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {brands.map((brand) => (
        <a
          href={`/brands/${brand.slug}/`}
          class="group card-hover flex flex-col rounded-2xl border border-surface-200 bg-white p-6 shadow-card"
        >
          <!-- Logo area -->
          <div class="flex h-12 w-full items-center overflow-hidden">
            {getBrandLogoUrl(brand) ? (
              <img
                src={getBrandLogoUrl(brand)!}
                alt={brand.name}
                class="max-h-10 w-auto max-w-full object-contain"
                loading="lazy"
              />
            ) : (
              <span class="text-sm font-semibold text-surface-500">{brand.name}</span>
            )}
          </div>

          <h2 class="mt-3 font-display text-lg font-bold text-surface-900 group-hover:text-brand-600 transition-colors">
            {brand.name}
          </h2>

          {brand.price_range_low && brand.price_range_high && (
            <p class="mt-0.5 text-sm font-medium text-surface-500">
              ${brand.price_range_low.toLocaleString()} – ${brand.price_range_high.toLocaleString()}
            </p>
          )}

          <p class="mt-2 text-sm leading-relaxed text-surface-600 line-clamp-2">{brand.description}</p>

          <div class="mt-4 flex flex-wrap gap-2 text-xs">
            {Number(brand.dealer_count) > 0 && (
              <span class="rounded-full bg-brand-50 px-2.5 py-1 font-semibold text-brand-700 ring-1 ring-brand-100">
                {Number(brand.dealer_count).toLocaleString()} tracked dealers
              </span>
            )}
            {brand.estimated_us_dealers && (
              <span class="rounded-full bg-surface-100 px-2.5 py-1 text-surface-600">
                ~{brand.estimated_us_dealers.toLocaleString()} US locations
              </span>
            )}
            {brand.affiliate_platform && Number(brand.affiliate_commission_rate) > 0 && (
              <span class="rounded-full bg-accent-50 px-2.5 py-1 font-medium text-accent-700 ring-1 ring-accent-100">
                {brand.affiliate_commission_rate}% affiliate
              </span>
            )}
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
