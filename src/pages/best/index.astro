---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/ui/Breadcrumb.astro';

const guides = [
  { title: 'Best eBikes Under $1,000', slug: 'best-ebikes-under-1000', description: 'Top picks for budget-conscious riders who want quality without breaking the bank.' },
  { title: 'Best eBikes Under $1,500', slug: 'best-ebikes-under-1500', description: 'The sweet spot for value — more features, better components, longer range.' },
  { title: 'Best eBikes Under $2,000', slug: 'best-ebikes-under-2000', description: 'Mid-range picks that deliver near-premium performance at a fair price.' },
  { title: 'Best eBikes Under $2,500', slug: 'best-ebikes-under-2500', description: 'Premium performance without stepping into flagship pricing.' },
  { title: 'Best eBikes Under $3,000', slug: 'best-ebikes-under-3000', description: 'Near-flagship bikes that outperform their price point.' },
  { title: 'Best Commuter eBikes', slug: 'best-commuter-ebikes', description: 'Practical, reliable daily riders built for roads, bike lanes, and light trails.' },
  { title: 'Best Cargo eBikes', slug: 'best-cargo-ebikes', description: 'Family and utility haulers that replace car trips with ease.' },
  { title: 'Best Fat Tire eBikes', slug: 'best-fat-tire-ebikes', description: 'All-terrain adventure bikes with 4"+ tires for sand, snow, and trail.' },
  { title: 'Best Folding eBikes', slug: 'best-folding-ebikes', description: 'Compact commuters that fit in apartments, car trunks, and offices.' },
  { title: 'Best Mountain eBikes', slug: 'best-mountain-ebikes', description: 'Trail-capable machines that let you ride harder and climb higher.' },
];
---

<BaseLayout
  title="Best eBikes — Expert Buying Guides by Price & Category"
  description="Expert eBike buying guides by price range and category. Find the best electric bike for your budget and riding style."
>
  <div class="mx-auto max-w-7xl px-(--spacing-page) py-8">
    <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Best eBikes' }]} />

    <h1 class="mt-6 text-3xl font-extrabold text-surface-900 md:text-4xl">Best eBike Buying Guides</h1>
    <p class="mt-2 text-lg text-surface-700">Expert picks by price range and riding category, updated for 2026.</p>

    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {guides.map((guide) => (
        <a href={`/best/${guide.slug}/`} class="group rounded-lg border border-surface-200 p-5 transition-shadow hover:shadow-md">
          <h2 class="font-bold text-surface-900 group-hover:text-brand-600 transition-colors">{guide.title}</h2>
          <p class="mt-1 text-sm text-surface-700">{guide.description}</p>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
