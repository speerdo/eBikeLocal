---
import { Image } from 'astro:assets';
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/ui/Breadcrumb.astro';

const guides = [
  {
    title: 'Best eBikes Under $1,000',
    slug: 'best-ebikes-under-1000',
    description: 'Top picks for budget-conscious riders who want quality without breaking the bank.',
    image: '/images/bikes/velotric-discover-1.png',
    badge: 'Budget',
  },
  {
    title: 'Best eBikes Under $1,500',
    slug: 'best-ebikes-under-1500',
    description: 'The sweet spot for value: more features, better components, and longer range.',
    image: '/images/bikes/aventon-level2.jpg',
    badge: 'Value',
  },
  {
    title: 'Best eBikes Under $2,000',
    slug: 'best-ebikes-under-2000',
    description: 'Mid-range picks that deliver near-premium performance at a fair price.',
    image: '/images/bikes/ride1up-prodigy-v2.webp',
    badge: 'Mid-Range',
  },
  {
    title: 'Best eBikes Under $2,500',
    slug: 'best-ebikes-under-2500',
    description: 'Premium performance without stepping into flagship pricing.',
    image: '/images/bikes/giant-explore-e-2-sta.jpg',
    badge: 'Premium Value',
  },
  {
    title: 'Best eBikes Under $3,000',
    slug: 'best-ebikes-under-3000',
    description: 'Near-flagship bikes that outperform their price point.',
    image: '/images/bikes/giant-talon-e-2.jpg',
    badge: 'Near Flagship',
  },
  {
    title: 'Best Commuter eBikes',
    slug: 'best-commuter-ebikes',
    description: 'Practical, reliable daily riders built for roads, bike lanes, and light trails.',
    image: '/images/bikes/specialized-turbo-vado-30.png',
    badge: 'Commuting',
  },
  {
    title: 'Best Cargo eBikes',
    slug: 'best-cargo-ebikes',
    description: 'Family and utility haulers that replace car trips with ease.',
    image: '/images/bikes/aventon-abound.jpg',
    badge: 'Utility',
  },
  {
    title: 'Best Fat Tire eBikes',
    slug: 'best-fat-tire-ebikes',
    description: 'All-terrain adventure bikes with 4"+ tires for sand, snow, and trail.',
    image: '/images/bikes/himiway-cruiser.jpg',
    badge: 'All-Terrain',
  },
  {
    title: 'Best Folding eBikes',
    slug: 'best-folding-ebikes',
    description: 'Compact commuters that fit in apartments, car trunks, and offices.',
    image: '/images/bikes/tern-vektron-s10.webp',
    badge: 'Portable',
  },
  {
    title: 'Best Mountain eBikes',
    slug: 'best-mountain-ebikes',
    description: 'Trail-capable machines that let you ride harder and climb higher.',
    image: '/images/bikes/giant-talon-e-2.jpg',
    badge: 'Trail',
  },
];
---

<BaseLayout
  title="Best eBikes — Expert Buying Guides by Price & Category"
  description="Expert eBike buying guides by price range and category. Find the best electric bike for your budget and riding style."
>
  <div class="mx-auto max-w-7xl page-x py-8">
    <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Best eBikes' }]} />

    <h1 class="mt-6 text-3xl font-extrabold text-surface-900 md:text-4xl">Best eBike Buying Guides</h1>
    <p class="mt-2 text-lg text-surface-700">Expert picks by price range and riding category, updated for 2026.</p>

    <section class="mt-8 overflow-hidden rounded-2xl border border-surface-200 bg-night-900">
      <div class="grid lg:grid-cols-2">
        <div class="p-6 md:p-8">
          <p class="inline-flex rounded-full border border-brand-300/40 bg-brand-400/15 px-3 py-1 text-xs font-700 uppercase tracking-wide text-brand-200">
            New for 2026
          </p>
          <h2 class="mt-4 text-2xl font-800 text-white md:text-3xl">Build your shortlist in minutes</h2>
          <p class="mt-3 max-w-xl text-sm leading-relaxed text-night-200">
            Start with your budget, compare the strongest options, and quickly see which bikes are worth test riding. Our guides focus on real ownership value, not spec sheet noise.
          </p>
          <div class="mt-5 flex flex-wrap gap-2 text-xs font-600 text-night-100">
            <span class="rounded-full border border-white/20 bg-white/10 px-2.5 py-1">Price tiers</span>
            <span class="rounded-full border border-white/20 bg-white/10 px-2.5 py-1">Category picks</span>
            <span class="rounded-full border border-white/20 bg-white/10 px-2.5 py-1">Updated model years</span>
          </div>
        </div>
        <div class="relative min-h-56">
          <Image
            src="https://images.pexels.com/photos/15009950/pexels-photo-15009950.jpeg?auto=compress&cs=tinysrgb&w=1400&dpr=1"
            alt="Two riders on electric bikes in an urban setting"
            width={1400}
            height={933}
            sizes="(max-width: 1024px) 100vw, 50vw"
            class="h-full w-full object-cover"
            loading="lazy"
          />
          <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-night-900/45 via-night-900/10 to-transparent"></div>
        </div>
      </div>
    </section>

    <section class="mt-6 max-w-3xl rounded-xl border border-surface-200 bg-surface-50 p-5 text-sm leading-relaxed text-surface-700">
      <p>
        These guides are built to help real riders make practical buying decisions, not just chase spec-sheet hype.
        We score each bike on ride quality, motor and battery performance, brake/safety spec, dealer support, and long-term value for the price.
        Models only make our top picks when they are consistently available from reputable brands with known customer support.
      </p>
      <p class="mt-3">
        We update this library throughout the year as brands release new model years, adjust pricing, or discontinue key bikes.
        Every guide includes who each bike is best for, where it compromises, and how it compares against alternatives in the same budget band.
      </p>
      <p class="mt-3">
        Categories currently cover budget to premium price tiers, plus use-case guides for commuting, cargo, folding, fat-tire, and trail riding.
        Use these pages as a shortlist builder, then jump to bike detail pages and local dealer pages to confirm fit, stock, and test-ride options.
      </p>
    </section>

    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {guides.map((guide) => (
        <a
          href={`/best/${guide.slug}/`}
          class="group overflow-hidden rounded-xl border border-surface-200 bg-white transition hover:-translate-y-0.5 hover:shadow-xl"
        >
          <div class="relative h-44 w-full overflow-hidden bg-surface-100">
            <img
              src={guide.image}
              alt={guide.title}
              class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
              loading="lazy"
            />
            <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-night-900/45 via-transparent to-transparent"></div>
            <span class="absolute left-3 top-3 rounded-full border border-white/25 bg-night-900/70 px-2.5 py-1 text-[11px] font-700 uppercase tracking-wide text-white">
              {guide.badge}
            </span>
          </div>
          <div class="p-5">
            <h2 class="font-bold text-surface-900 transition-colors group-hover:text-brand-600">{guide.title}</h2>
            <p class="mt-1 text-sm text-surface-700">{guide.description}</p>
            <p class="mt-4 text-sm font-700 text-brand-600">Read guide -></p>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
