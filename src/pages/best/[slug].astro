---
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/ui/Breadcrumb.astro';
import AffiliateDisclosureBar from '@components/ui/AffiliateDisclosureBar.astro';

export async function getStaticPaths() {
  const entries = await getCollection('bestOf');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const { title, description, publishedAt, updatedAt, heroImage, priceMax } = entry.data;

const dateStr = (updatedAt ?? publishedAt).toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});

// Related guides: all bestOf entries except current
const allBestOf = await getCollection('bestOf');
const relatedGuides = allBestOf
  .filter((e) => e.id !== entry.id)
  .sort((a, b) => {
    // Price guides first, then category guides
    const aPrice = a.data.priceMax ?? 0;
    const bPrice = b.data.priceMax ?? 0;
    if (aPrice && bPrice) return aPrice - bPrice;
    if (aPrice) return -1;
    if (bPrice) return 1;
    return a.data.title.localeCompare(b.data.title);
  })
  .slice(0, 5);

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: publishedAt.toISOString(),
  dateModified: (updatedAt ?? publishedAt).toISOString(),
  image: heroImage || undefined,
  mainEntityOfPage: `${import.meta.env.SITE_URL || 'https://ebikelocal.com'}/best/${entry.id}/`,
  author: {
    '@type': 'Organization',
    name: 'eBikeLocal',
  },
  publisher: {
    '@type': 'Organization',
    name: 'eBikeLocal',
  },
};
---

<BaseLayout
  title={`${title} | eBikeLocal`}
  description={description}
  ogImage={heroImage}
  jsonLd={articleSchema}
>
  <!-- Hero header -->
  <section class="relative overflow-hidden bg-night-900">
    {heroImage && (
      <div class="absolute inset-0 pointer-events-none">
        <Image
          src={heroImage}
          alt={`${title} — article hero photograph`}
          width={1260}
          height={750}
          sizes="100vw"
          class="h-full w-full object-cover opacity-20"
          loading="eager"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-night-900 via-night-900/85 to-night-900/50"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-night-900/60 to-transparent"></div>
      </div>
    )}
    <div class="absolute inset-0 bg-circuit pointer-events-none opacity-60"></div>
    <div class="absolute -top-24 right-0 h-72 w-72 rounded-full bg-brand-400/8 blur-3xl pointer-events-none"></div>

    <div class="relative mx-auto max-w-4xl page-x py-12 md:py-16">
      <Breadcrumb items={[
        { label: 'Home', href: '/' },
        { label: 'Best Picks', href: '/best/' },
        { label: title },
      ]} />

      <div class="mt-5">
        <div class="mb-4 w-10 h-[3px] rounded-full bg-gradient-to-r from-brand-400 to-electric-400"></div>
        <span class="inline-block text-[11px] font-700 uppercase tracking-widest text-brand-400 mb-3">
          Best eBikes {priceMax ? `Under $${priceMax.toLocaleString()}` : '2026'}
        </span>
        <h1 class="font-display text-3xl font-700 tracking-tight text-white md:text-4xl lg:text-[2.5rem] leading-[1.1]">
          {title}
        </h1>
        <p class="mt-3 max-w-2xl text-lg text-night-300 leading-relaxed">{description}</p>
        <p class="mt-4 text-xs text-night-500">Updated {dateStr}</p>
      </div>
    </div>
  </section>

  <!-- Article body -->
  <div class="mx-auto max-w-4xl page-x py-10 md:py-14">
    <AffiliateDisclosureBar className="mb-6" />
    <div class="flex gap-10">

      <!-- Main content -->
      <article class="min-w-0 flex-1 prose prose-slate max-w-none
        prose-headings:font-display prose-headings:font-700 prose-headings:tracking-tight
        prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4 prose-h2:text-surface-900 prose-h2:border-b prose-h2:border-surface-100 prose-h2:pb-3
        prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3 prose-h3:text-surface-900
        prose-p:text-surface-700 prose-p:leading-relaxed prose-p:mb-4
        prose-a:text-brand-600 prose-a:font-500 prose-a:no-underline hover:prose-a:underline
        prose-strong:text-surface-900 prose-strong:font-700
        prose-ul:text-surface-700 prose-ol:text-surface-700
        prose-li:mb-1.5
        prose-table:text-sm
        prose-th:bg-surface-50 prose-th:font-600 prose-th:text-surface-800
        prose-td:text-surface-700
        prose-hr:border-surface-200
        prose-blockquote:not-italic prose-blockquote:border-l-brand-400 prose-blockquote:bg-brand-50 prose-blockquote:rounded-r-lg
      ">
        <Content />
      </article>

      <!-- ToC sidebar -->
      {headings.filter(h => h.depth <= 2).length > 2 && (
        <aside class="hidden xl:block w-56 shrink-0">
          <div class="sticky top-24">
            <p class="text-xs font-700 uppercase tracking-widest text-surface-500 mb-3">Our Picks</p>
            <nav>
              <ul class="space-y-1.5 text-sm">
                {headings
                  .filter(h => h.depth <= 2)
                  .map(h => (
                    <li>
                      <a
                        href={`#${h.slug}`}
                        class="block text-surface-600 hover:text-brand-600 transition-colors leading-snug"
                      >
                        {h.text}
                      </a>
                    </li>
                  ))
                }
              </ul>
            </nav>
          </div>
        </aside>
      )}
    </div>

    <!-- CTA -->
    <div class="mt-10 rounded-2xl bg-night-900 p-7 relative overflow-hidden">
      <div class="absolute inset-0 bg-circuit opacity-60 pointer-events-none"></div>
      <div class="absolute top-0 right-0 h-40 w-40 rounded-full bg-brand-400/8 blur-2xl pointer-events-none"></div>
      <div class="relative">
        <div class="mb-3 w-8 h-[3px] rounded-full bg-gradient-to-r from-brand-400 to-electric-400"></div>
        <h3 class="font-display text-lg font-700 text-white">
          Find a Dealer for Any of These Bikes
        </h3>
        <p class="mt-1.5 text-sm text-night-400 max-w-md">
          See which shops near you carry Aventon, Trek, Velotric, Lectric, and other top brands.
        </p>
        <div class="mt-4 flex flex-wrap gap-3">
          <a href="/shops/" class="btn-volt inline-flex rounded-xl px-5 py-2.5 text-sm">
            Find Local Shops →
          </a>
          <a href="/brands/" class="btn-outline-volt inline-flex rounded-xl px-5 py-2.5 text-sm">
            Compare All Brands
          </a>
        </div>
      </div>
    </div>

    <!-- Related buying guides -->
    {relatedGuides.length > 0 && (
      <div class="mt-10">
        <h3 class="text-sm font-700 uppercase tracking-widest text-surface-500 mb-4">More Buying Guides</h3>
        <div class="flex flex-wrap gap-3">
          {relatedGuides.map((g) => (
            <a href={`/best/${g.id}/`} class="rounded-xl border border-surface-200 bg-white px-4 py-2.5 text-sm font-500 text-surface-700 hover:border-brand-200 hover:text-brand-700 transition-colors shadow-card">
              {g.data.title}
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Cross-links: top brands + dealer finder -->
    <div class="mt-8 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-surface-100 bg-surface-50 p-5">
        <h3 class="text-sm font-700 text-surface-800 mb-3">Find These Bikes Locally</h3>
        <ul class="space-y-2 text-sm">
          {[
            { title: 'Aventon Dealers', href: '/brands/aventon/dealers/' },
            { title: 'Trek eBike Dealers', href: '/brands/trek/dealers/' },
            { title: 'Lectric Dealers', href: '/brands/lectric/dealers/' },
            { title: 'Velotric Dealers', href: '/brands/velotric/dealers/' },
          ].map(b => (
            <li><a href={b.href} class="text-brand-600 hover:underline">{b.title} →</a></li>
          ))}
        </ul>
      </div>
      <div class="rounded-xl border border-surface-100 bg-surface-50 p-5">
        <h3 class="text-sm font-700 text-surface-800 mb-3">eBike Guides</h3>
        <ul class="space-y-2 text-sm">
          {[
            { title: 'How to Choose an eBike', href: '/guides/how-to-choose-an-ebike/' },
            { title: 'eBike Tax Credit 2026', href: '/guides/ebike-tax-credit-2026/' },
            { title: 'eBike Laws by State', href: '/guides/ebike-laws-by-state/' },
            { title: 'eBike Classes Explained', href: '/guides/ebike-classes-explained/' },
          ].map(g => (
            <li><a href={g.href} class="text-brand-600 hover:underline">{g.title} →</a></li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</BaseLayout>
